add_ratelimit() {
    local proto port rate burst compact_rate compact_burst rc changed=0 snap
    read -r -p "请输入协议 (tcp/udp，默认 tcp): " proto
    [[ -z "$proto" ]] && proto="tcp"
    validate_proto_rule "$proto" || { log_error "协议输入无效。"; return; }

    read -r -p "请输入需要限速的端口号: " port
    validate_port "$port" || { log_error "端口号无效。"; return; }

    read -r -p "请输入最大速率 (如 10/minute、100kbytes/second 或 100 kbytes/second): " rate
    compact_rate="$(normalize_rate_value "$rate")"
    validate_rate "$compact_rate" || { log_error "速率格式无效。"; return; }

    if rate_is_byte_based "$compact_rate"; then
        read -r -p "请输入 burst（可留空，字节速率示例：100kbytes）: " burst
    else
        read -r -p "请输入 burst（可留空，包速率示例：20 或 20packets）: " burst
    fi

    compact_burst="$(normalize_burst_value "$burst")"
    snap="$(make_file_snapshot "$RATELIMIT_FILE")" || { log_error "无法创建文件快照，已取消写入。"; return; }

    if [[ -n "$compact_burst" ]]; then
        validate_burst_token "$compact_burst" || { rm -f "$snap"; log_error "burst 格式无效。"; return; }
        if rate_is_byte_based "$compact_rate"; then
            [[ "$compact_burst" =~ ^[0-9]+(bytes|kbytes|mbytes|gbytes)$ ]] || { rm -f "$snap"; log_error "字节速率的 burst 必须带 bytes/kbytes/mbytes/gbytes 单位。"; return; }
        else
            [[ "$compact_burst" =~ ^[0-9]+(packets)?$ ]] || { rm -f "$snap"; log_error "包速率的 burst 只能是不带单位的数字或 packets。"; return; }
        fi
        append_unique_line "$proto $port $compact_rate $compact_burst" "$RATELIMIT_FILE"; rc=$?
    else
        append_unique_line "$proto $port $compact_rate" "$RATELIMIT_FILE"; rc=$?
    fi
    (( rc == 1 )) && { rm -f "$snap"; return; }
    (( rc == 0 )) && changed=1

    if ! port_is_effectively_allowed "$proto" "$port"; then
        log_warn "提示：该端口尚未在 allow.list / allow_range.list / allow_acl.list 中放行；仅添加限速规则不会自动开放端口。"
    fi

    if (( changed )); then
        apply_with_file_rollback "$RATELIMIT_FILE" "$snap" "规则应用失败" "速率限制规则已添加。" || return
    else
        rm -f "$snap"
        log_info "规则已存在，未修改限速列表。"
    fi
}


