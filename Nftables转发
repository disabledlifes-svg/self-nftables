uninstall_clean() {
    local keep_backup residual_line residual_found=0
    echo -e "
${RED}⚠️ 警告：此操作将删除本脚本配置的所有规则、服务、配置文件，并尝试移除专用 sysctl 配置。${PLAIN}"
    read -r -p "确定要彻底卸载并清理吗？[y/N]: " confirm
    if [[ "${confirm,,}" == "y" ]]; then
        if ! validate_uninstall_targets_safe; then
            log_error "检测到卸载目标路径不安全，已拒绝继续卸载。"
            return 1
        fi

        log_warn "正在停止并移除 systemd 服务..."
        if systemd_is_usable; then
            systemctl stop nft-manager.service >/dev/null 2>&1 || true
            systemctl disable nft-manager.service >/dev/null 2>&1 || true
            systemctl reset-failed nft-manager.service >/dev/null 2>&1 || true
        fi
        rm -f "$SERVICE_FILE" "$SERVICE_WANTS_LINK" "$LOADER_FILE"
        systemd_is_usable && systemctl daemon-reload >/dev/null 2>&1 || true

        log_warn "正在清除 nftables 中的脚本专属规则表..."
        if ! drop_managed_tables_quiet; then
            log_warn "受管表清理未完全成功；将继续执行卸载，并在最后统一复核残留项。"
        fi

        log_warn "正在删除配置目录..."
        rm -rf "$CONF_DIR"

        read -r -p "是否保留备份文件 ($BACKUP_DIR)？[Y/n]: " keep_backup
        if [[ "${keep_backup,,}" == "n" ]]; then
            rm -rf "$BACKUP_DIR"
            log_warn "备份文件已删除。"
        else
            purge_runtime_state_backups
            log_warn "已清理运行态快照，仅保留手工备份文件。"
        fi

        log_warn "正在移除专用 sysctl 配置并关闭 forwarding..."
        rm -f "$SYSCTL_FILE"
        sysctl -w net.ipv4.ip_forward=0 >/dev/null 2>&1 || true
        sysctl -w net.ipv6.conf.all.forwarding=0 >/dev/null 2>&1 || true
        sysctl --system >/dev/null 2>&1 || true

        log_warn "正在清理锁文件与残留状态..."
        rm -rf "$LOCK_DIR" 2>/dev/null || true
        rm -f "$LOCK_FILE" 2>/dev/null || true

        if uninstall_collect_residuals "$keep_backup"; then
            if [[ "${keep_backup,,}" == "n" ]]; then
                log_ok "✅ 卸载完成，未发现残留项。"
            else
                log_ok "✅ 卸载完成，未发现非保留型残留项（手工备份按你的选择已保留）。"
            fi
            if ! uninstall_collect_advisories; then
                log_warn "同时检测到以下环境告警（不视为本脚本残留项）："
                while IFS= read -r residual_line; do
                    [[ -z "$residual_line" ]] && continue
                    echo -e "${YELLOW} - ${residual_line}${PLAIN}"
                done < <(uninstall_collect_advisories || true)
            fi
            exit 0
        fi

        log_warn "卸载已执行，但仍检测到以下残留项："
        while IFS= read -r residual_line; do
            [[ -z "$residual_line" ]] && continue
            residual_found=1
            echo -e "${YELLOW} - ${residual_line}${PLAIN}"
        done < <(uninstall_collect_residuals "$keep_backup" || true)
        (( residual_found == 0 )) || log_warn "请按上述残留项逐项手动检查。"
        if ! uninstall_collect_advisories; then
            log_warn "同时检测到以下环境告警（不视为本脚本残留项）："
            while IFS= read -r residual_line; do
                [[ -z "$residual_line" ]] && continue
                echo -e "${YELLOW} - ${residual_line}${PLAIN}"
            done < <(uninstall_collect_advisories || true)
        fi
        exit 1
    else
        log_ok "已取消卸载操作。"
    fi
}


show_numbered_active_entries() {
    local file="$1"
    local line raw display idx=0 raw_lineno=0 invalid_flag=0
    validate_runtime_managed_paths_safe || return 1
    ACTIVE_LINE_MAP=()
    ACTIVE_INVALID_MAP=()

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        raw_lineno=$((raw_lineno + 1))
        line="$(normalize_line "$raw")"
        [[ -z "$line" ]] && continue
        display="$(canonicalize_entry "$file" "$raw" 2>/dev/null || true)"
        invalid_flag=0
        if [[ -z "$display" ]]; then
            display="[INVALID] $line"
            invalid_flag=1
        fi
        idx=$((idx + 1))
        ACTIVE_LINE_MAP+=("$raw_lineno")
        ACTIVE_INVALID_MAP+=("$invalid_flag")
        printf '%4d  %s
' "$idx" "$display"
    done < "$file"

    (( idx > 0 ))
}

delete_item() {
    local file="$1" title="$2" num max target_line snap target_invalid=0
    echo -e "${CYAN}--- $title ---${PLAIN}"
    if ! show_numbered_active_entries "$file"; then
        echo -e "${YELLOW}列表为空。${PLAIN}"
        return 0
    fi

    max="${#ACTIVE_LINE_MAP[@]}"
    read -r -p "请输入要删除的序号: " num
    if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= max )); then
        target_line="${ACTIVE_LINE_MAP[$((num - 1))]}"
        target_invalid="${ACTIVE_INVALID_MAP[$((num - 1))]:-0}"
        snap="$(make_file_snapshot "$file")" || { log_error "无法创建文件快照，已取消删除。"; return 1; }
        if ! delete_physical_line_atomic "$file" "$target_line"; then
            rm -f "$snap"
            log_error "删除失败：无法原子写回文件 $file"
            return 1
        fi

        if apply_rules; then
            rm -f "$snap"
            log_ok "已删除。"
            return 0
        fi

        if [[ "$target_invalid" == "1" ]] && has_any_invalid_rule_entries; then
            rm -f "$snap"
            log_warn "已删除一条无效配置行，但其余无效条目仍存在；本次仅完成配置清理，运行态未更新。请继续清理后再重新应用。"
            return 0
        fi

        if revert_file_from_snapshot "$file" "$snap"; then
            log_warn "规则应用失败 已撤销本次文件修改。"
        else
            log_error "规则应用失败 且文件回滚失败，请手动检查：$file"
        fi
        rm -f "$snap"
        return 1
    else
        log_error "无效输入！"
        return 1
    fi
}

