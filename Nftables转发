load_settings() {
    [[ -f "$SETTINGS_FILE" ]] || return 0

    local raw line key value
    while IFS= read -r raw || [[ -n "$raw" ]]; do
        raw="${raw#$'\xEF\xBB\xBF'}"
        raw="${raw%$'\r'}"
        line="$(trim "$raw")"
        [[ -z "$line" || "$line" == \#* ]] && continue
        [[ "$line" =~ ^(export[[:space:]]+)?([A-Z_][A-Z0-9_]*)[[:space:]]*=[[:space:]]*(.*)$ ]] || continue

        key="${BASH_REMATCH[2]}"
        value="$(trim "${BASH_REMATCH[3]}")"

        if [[ "$value" =~ ^\"(.*)\"([[:space:]]*#.*)?$ ]]; then
            value="${BASH_REMATCH[1]}"
        elif [[ "$value" =~ ^\'([^\']*)\'([[:space:]]*#.*)?$ ]]; then
            value="${BASH_REMATCH[1]}"
        else
            value="$(trim "$(strip_inline_comment "$value")")"
        fi

        value="${value%$'\r'}"
        apply_setting_kv "$key" "$value"
    done < "$SETTINGS_FILE"
}
