uninstall_collect_residuals() {
    local keep_backups="$1"
    local state enabled_state active_state
    local -a residuals=()

    [[ -e "$SERVICE_FILE" || -L "$SERVICE_FILE" ]] && residuals+=("systemd 服务文件: $SERVICE_FILE")
    [[ -e "$SERVICE_WANTS_LINK" || -L "$SERVICE_WANTS_LINK" ]] && residuals+=("systemd wants 链接: $SERVICE_WANTS_LINK")
    [[ -e "$LOADER_FILE" || -L "$LOADER_FILE" ]] && residuals+=("loader 文件: $LOADER_FILE")
    [[ -e "$CONF_DIR" || -L "$CONF_DIR" ]] && residuals+=("配置目录: $CONF_DIR")
    [[ -e "$LOCK_FILE" || -L "$LOCK_FILE" ]] && residuals+=("锁文件: $LOCK_FILE")
    [[ -e "$LOCK_DIR" || -L "$LOCK_DIR" ]] && residuals+=("锁目录: $LOCK_DIR")
    [[ -e "$SYSCTL_FILE" || -L "$SYSCTL_FILE" ]] && residuals+=("sysctl 文件: $SYSCTL_FILE")

    if [[ "${keep_backups,,}" == "n" ]]; then
        [[ -e "$BACKUP_DIR" || -L "$BACKUP_DIR" ]] && residuals+=("备份目录: $BACKUP_DIR")
    else
        [[ -e "$RUNTIME_DIR" || -L "$RUNTIME_DIR" ]] && residuals+=("运行态快照目录: $RUNTIME_DIR")
    fi

    state="$(managed_tables_runtime_state)"
    [[ "$state" != "missing" ]] && residuals+=("受管表运行态: $state")

    if systemd_is_usable; then
        enabled_state="$(systemctl is-enabled nft-manager.service 2>/dev/null || true)"
        case "$enabled_state" in
            enabled|linked|linked-runtime|alias|indirect|generated|transient|static)
                residuals+=("systemd 启用状态: $enabled_state")
                ;;
        esac
        active_state="$(systemctl is-active nft-manager.service 2>/dev/null || true)"
        case "$active_state" in
            active|activating|deactivating|failed|reloading)
                residuals+=("systemd 当前状态: $active_state")
                ;;
        esac
    fi

    if (( ${#residuals[@]} > 0 )); then
        printf '%s
' "${residuals[@]}"
        return 1
    fi
    return 0
}

uninstall_collect_advisories() {
    local v4_now v6_now
    local -a advisories=()

    if sysctl_key_exists "net.ipv4.ip_forward"; then
        v4_now="$(sysctl -n net.ipv4.ip_forward 2>/dev/null || echo unknown)"
        [[ "$v4_now" != "0" ]] && advisories+=("IPv4 转发当前值仍为 $v4_now（可能由外部系统配置或其他服务重新启用）")
    fi
    if sysctl_key_exists "net.ipv6.conf.all.forwarding"; then
        v6_now="$(sysctl -n net.ipv6.conf.all.forwarding 2>/dev/null || echo unknown)"
        [[ "$v6_now" != "0" ]] && advisories+=("IPv6 转发当前值仍为 $v6_now（可能由外部系统配置或其他服务重新启用）")
    fi

    if (( ${#advisories[@]} > 0 )); then
        printf '%s
' "${advisories[@]}"
        return 1
    fi
    return 0
}

