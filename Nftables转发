    fi

    write_sysctl_values "$desired_v4" "$desired_v6"
}


SNAPSHOT_META_FORMAT=""
SNAPSHOT_META_V4=""
SNAPSHOT_META_V6=""

snapshot_metadata_read_values() {
    local file="$1" line trimmed any_meta=0 format_count=0 v4_count=0 v6_count=0 header_open=1

    SNAPSHOT_META_FORMAT=""
    SNAPSHOT_META_V4=""
    SNAPSHOT_META_V6=""

    [[ -f "$file" && -s "$file" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        trimmed="$(trim "$line")"

        if [[ "$trimmed" == '#!'* ]]; then
            (( header_open == 1 )) || return 1
            continue
        fi

        if [[ -z "$trimmed" ]]; then
            (( header_open == 1 )) && continue
            break
        fi

        if (( header_open == 1 )); then
            case "$trimmed" in
                '# NFTMGR_SNAPSHOT_FORMAT='*)
                    any_meta=1
                    [[ "$trimmed" =~ ^#\ NFTMGR_SNAPSHOT_FORMAT=([0-9]+)$ ]] || return 1
                    SNAPSHOT_META_FORMAT="${BASH_REMATCH[1]}"
                    format_count=$((format_count + 1))
                    continue
                    ;;
                '# NFTMGR_IPV4_FORWARD='*)
                    any_meta=1
                    [[ "$trimmed" =~ ^#\ NFTMGR_IPV4_FORWARD=([01])$ ]] || return 1
                    SNAPSHOT_META_V4="${BASH_REMATCH[1]}"
                    v4_count=$((v4_count + 1))
                    continue
                    ;;
                '# NFTMGR_IPV6_FORWARD='*)
                    any_meta=1
                    [[ "$trimmed" =~ ^#\ NFTMGR_IPV6_FORWARD=([01])$ ]] || return 1
                    SNAPSHOT_META_V6="${BASH_REMATCH[1]}"
                    v6_count=$((v6_count + 1))
                    continue
                    ;;
                '# NFTMGR_'*)
                    return 1
                    ;;
                '# '*)
                    continue
                    ;;
                '#')
                    continue
                    ;;
            esac
            header_open=0
        fi

        if [[ "$trimmed" == '# NFTMGR_'* ]]; then
            return 1
        fi
    done < "$file"

    if (( any_meta == 0 )); then
        return 2
    fi

    if (( format_count == 0 )); then
        (( v4_count == 1 && v6_count == 1 )) || return 1
        return 3
    fi

    [[ "$SNAPSHOT_META_FORMAT" == "1" ]] || return 1
    (( format_count == 1 && v4_count == 1 && v6_count == 1 )) || return 1
    return 0
}

snapshot_metadata_is_usable() {
    snapshot_metadata_read_values "$1"
    [[ $? -eq 0 ]]
}
managed_nft_content_is_usable() {
    local file="$1" require_tables="${2:-yes}" line found_table=0
    local family name seen_nat=0 seen_fw=0 brace_depth=0 opens closes delta metadata_rc

    [[ -f "$file" && -s "$file" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line%$'
'}"
        line="$(trim "$line")"
        [[ -z "$line" || "$line" == \#* ]] && continue

        case "$line" in
            table\ *)
                (( brace_depth == 0 )) || return 1
                if [[ "$line" =~ ^table[[:space:]]+([[:alnum:]_]+)[[:space:]]+([[:alnum:]_]+)[[:space:]]*\{$ ]]; then
                    family="${BASH_REMATCH[1]}"
                    name="${BASH_REMATCH[2]}"
                    case "$family:$name" in
                        ip:$TABLE_NAT)
                            (( seen_nat == 0 )) || return 1
                            seen_nat=1
                            found_table=1
                            ;;
                        inet:$TABLE_FW)
                            (( seen_fw == 0 )) || return 1
                            seen_fw=1
                            found_table=1
                            ;;
                        *)
                            return 1
                            ;;
                    esac
                else
                    return 1
                fi
                ;;
            flush\ *|add\ *|delete\ *|list\ *|include\ *|define\ *|redefine\ *|undefine\ *|rename\ *|destroy\ *)
                return 1
                ;;
            *)
                (( found_table == 1 )) || return 1
                if (( brace_depth <= 0 )) && [[ "$line" != '}' ]]; then
                    return 1
                fi
                ;;
        esac

        opens="${line//[^\{]/}"
        closes="${line//[^\}]/}"
        delta=$(( ${#opens} - ${#closes} ))
        brace_depth=$(( brace_depth + delta ))
        (( brace_depth >= 0 )) || return 1
    done < "$file"

    (( brace_depth == 0 )) || return 1

    snapshot_metadata_read_values "$file"
    metadata_rc=$?

    if (( found_table == 1 )); then
        (( seen_nat == 1 && seen_fw == 1 )) || return 1
        (( metadata_rc == 0 || metadata_rc == 2 || metadata_rc == 3 )) || return 1
    else
        (( metadata_rc == 0 )) || return 1
    fi

    if [[ "$require_tables" == "yes" ]]; then
        (( found_table == 1 )) || return 1
    fi

    return 0
}

