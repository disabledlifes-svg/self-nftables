    validate_yesno "$ALLOW_PING_V4" || { log_error "settings.conf 中 ALLOW_PING_V4 必须为 yes/no。"; rc=1; }
    validate_yesno "$ALLOW_PING_V6" || { log_error "settings.conf 中 ALLOW_PING_V6 必须为 yes/no。"; rc=1; }
    validate_yesno "$ALLOW_IPV6_ND" || { log_error "settings.conf 中 ALLOW_IPV6_ND 必须为 yes/no。"; rc=1; }
    validate_yesno "$ENABLE_IPV6_FORWARD" || { log_error "settings.conf 中 ENABLE_IPV6_FORWARD 必须为 yes/no。"; rc=1; }
    validate_yesno "$WARN_IPTABLES_NAT_CONFLICT" || { log_error "settings.conf 中 WARN_IPTABLES_NAT_CONFLICT 必须为 yes/no。"; rc=1; }
    validate_yesno "$ENABLE_COUNTERS" || { log_error "settings.conf 中 ENABLE_COUNTERS 必须为 yes/no。"; rc=1; }
    validate_rate "$(normalize_rate_value "$DROP_LOG_RATE")" || { log_error "settings.conf 中 DROP_LOG_RATE 格式无效。"; rc=1; }
    validate_rate "$(normalize_rate_value "$PING_V4_RATE")" || { log_error "settings.conf 中 PING_V4_RATE 格式无效。"; rc=1; }
    validate_iface_name_syntax "$WAN_IFACE" || { log_error "settings.conf 中 WAN_IFACE 名称格式无效。"; rc=1; }

    if (( rc != 0 )); then
        [[ "$fatal" == "fatal" ]] && exit 1
        return 1
    fi

    if [[ -n "$WAN_IFACE" ]] && ! iface_exists "$WAN_IFACE"; then
        if [[ "$fatal" == "fatal" ]]; then
            log_warn "settings.conf 中指定的 WAN_IFACE=$WAN_IFACE 当前不存在；你仍可进入菜单修改规则，但涉及转发的校验/应用会失败。"
        else
            log_error "settings.conf 中 WAN_IFACE=$WAN_IFACE 当前不存在。"
            return 1
        fi
    fi

    return 0
