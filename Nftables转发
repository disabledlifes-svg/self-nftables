    if ! systemctl daemon-reload >/dev/null 2>&1; then
        log_warn "systemd daemon-reload 失败；服务定义可能尚未刷新到最新版本。"
        rc=1
    fi
    if ! systemctl enable nft-manager.service >/dev/null 2>&1; then
        log_warn "nft-manager.service enable 失败；重启后可能不会自动加载最新规则。"
        rc=1
