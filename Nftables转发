    [[ -z "$WAN_IFACE" ]] && return 1
    iface_exists "$WAN_IFACE"
}

full_syntax_check_quiet() {
    local tmp_file rc=1
    tmp_file="$(safe_mktemp_file nft-manager-status.XXXXXX.nft)" || return 1

    if generate_rules_file "$tmp_file" no >/dev/null 2>&1 && "$NFT_BIN" -c -f "$tmp_file" >/dev/null 2>&1; then
        rc=0
    fi

    rm -f "$tmp_file"
    return "$rc"
}

run_preflight_checks() {
    load_runtime_settings || return 1

    validate_iface_name_syntax "$WAN_IFACE" || {
        log_error "自动探测到的 WAN_IFACE 名称无效：${WAN_IFACE:-<empty>}"
        return 1
    }

    validate_settings_or_warn nonfatal || return 1

    if has_valid_entries "$FORWARD_FILE"; then
        require_wan_iface_for_forwarding || {
            log_error "检测到 forward.list 中存在有效 DNAT 转发规则，但当前无法确定可用的 WAN_IFACE。请在 $SETTINGS_FILE 中手动设置正确的 WAN_IFACE。"
            return 1
        }
    fi

    return 0
}

systemd_is_usable() {
    command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]
}

managed_tables_runtime_state() {
    local tables_out nat_present=0 fw_present=0

    [[ -n "$NFT_BIN" ]] || { printf 'unknown(nft-unavailable)'; return; }

    tables_out="$("$NFT_BIN" list tables 2>/dev/null)" || { printf 'unknown(query-failed)'; return; }

    grep -Eq "^[[:space:]]*table[[:space:]]+ip[[:space:]]+$TABLE_NAT([[:space:]]|$)" <<< "$tables_out" && nat_present=1
    grep -Eq "^[[:space:]]*table[[:space:]]+inet[[:space:]]+$TABLE_FW([[:space:]]|$)" <<< "$tables_out" && fw_present=1

    if (( nat_present == 1 && fw_present == 1 )); then
        printf 'present'
    elif (( nat_present == 1 )); then
        printf 'partial(nat-only)'
    elif (( fw_present == 1 )); then
        printf 'partial(fw-only)'
    else
        printf 'missing'
    fi
}

managed_tables_are_absent() {
    local tables_out
    [[ -n "$NFT_BIN" ]] || return 1
    tables_out="$("$NFT_BIN" list tables 2>/dev/null)" || return 1
    grep -Eq "^[[:space:]]*table[[:space:]]+ip[[:space:]]+$TABLE_NAT([[:space:]]|$)" <<< "$tables_out" && return 1
    grep -Eq "^[[:space:]]*table[[:space:]]+inet[[:space:]]+$TABLE_FW([[:space:]]|$)" <<< "$tables_out" && return 1
    return 0
}

drop_managed_tables_quiet() {
    [[ -n "$NFT_BIN" ]] || return 1

    "$NFT_BIN" delete table ip "$TABLE_NAT" >/dev/null 2>&1 || true
    "$NFT_BIN" delete table inet "$TABLE_FW" >/dev/null 2>&1 || true

    managed_tables_are_absent
}

warn_iptables_nat_conflict() {
    [[ "$WARN_IPTABLES_NAT_CONFLICT" == "yes" ]] || return 0
    command -v iptables >/dev/null 2>&1 || return 0

    local nat_rules
    nat_rules="$(iptables -t nat -S 2>/dev/null || true)"
    [[ -n "$nat_rules" ]] || return 0

    if grep -qE '^-A (PREROUTING|POSTROUTING|OUTPUT) ' <<< "$nat_rules"; then
        log_warn "检测到系统已有 iptables NAT 规则；与 nftables 或其他防火墙服务混用时可能出现优先级/命中差异。"
    fi
}

init_env() {
    ensure_nft_installed
    ensure_dirs || { log_error "初始化配置目录失败，无法继续运行。"; exit 1; }
    load_runtime_settings || { log_error "受管配置文件或目录不安全，无法继续运行。"; exit 1; }

    if ! validate_iface_name_syntax "$WAN_IFACE"; then
        log_warn "自动探测到的 WAN_IFACE 名称无效：${WAN_IFACE:-<empty>}；已忽略，涉及 DNAT 时请手动设置。"
        WAN_IFACE=""
    fi

    if ! validate_settings_or_warn nonfatal; then
        log_warn "检测到 settings.conf 存在问题；你仍可进入菜单修复，但校验/应用规则前必须先修正。"
    fi

    if ! write_service; then
        log_warn "systemd 持久化文件更新失败；当前菜单仍可使用，但重启后可能无法自动恢复规则。"
    fi
    warn_iptables_nat_conflict
}

generate_trace_prerouting_rules() {
    local outfile="$1"
    local line proto port src raw_line
    local -a trace_rules=()

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        line="$(canonicalize_entry "$TRACE_FILE" "$raw_line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "trace.list 格式无效：$raw_line"; return 1; }
            continue
        }
        trace_rules+=("$line")
    done < "$TRACE_FILE"

    if (( ${#trace_rules[@]} > 0 )); then
        mapfile -t trace_rules < <(dedupe_scalar_array "${trace_rules[@]}")
    fi

    for line in "${trace_rules[@]}"; do
        read -r proto port src <<< "$line"
        validate_proto_rule "$proto" || { log_error "trace.list 协议无效：$line"; return 1; }
        validate_port "$port" || { log_error "trace.list 端口无效：$line"; return 1; }
        if [[ -n "$src" ]]; then
            validate_ip_or_cidr "$src" || { log_error "trace.list 源地址无效：$line"; return 1; }
            if is_ipv6_value "$src"; then
                echo "        ip6 saddr $src $proto dport $port $(counter_stmt)meta nftrace set 1" >> "$outfile"
            else
                echo "        ip saddr $src $proto dport $port $(counter_stmt)meta nftrace set 1" >> "$outfile"
            fi
        else
            echo "        $proto dport $port $(counter_stmt)meta nftrace set 1" >> "$outfile"
        fi
    done
}

ipv4_cidr_to_range() {
    ipv4_value_to_range "$1"
}

ipv4_cidrs_overlap() {
    local left="$1" right="$2"
    local lstart lend rstart rend
    read -r lstart lend <<< "$(ipv4_cidr_to_range "$left")" || return 1
    read -r rstart rend <<< "$(ipv4_cidr_to_range "$right")" || return 1
    (( lstart <= rend && rstart <= lend ))
}

validate_forward_rule_collisions() {
    local -a rules=("$@")
    local i j proto_i lport_i rip_i rport_i src_i proto_j lport_j rip_j rport_j src_j

    for (( i = 0; i < ${#rules[@]}; i++ )); do
        src_i=""
        read -r proto_i lport_i rip_i rport_i src_i <<< "${rules[$i]}"
        for (( j = i + 1; j < ${#rules[@]}; j++ )); do
            src_j=""
            read -r proto_j lport_j rip_j rport_j src_j <<< "${rules[$j]}"
            [[ "$proto_i" == "$proto_j" && "$lport_i" == "$lport_j" ]] || continue

            if [[ -z "$src_i" && -z "$src_j" ]]; then
                log_error "forward.list 存在冲突：$proto_i/$lport_i 存在多条无源限制 DNAT 规则：${rules[$i]} | ${rules[$j]}"
                return 1
            fi

            if [[ -n "$src_i" && -n "$src_j" && "$src_i" == "$src_j" ]]; then
                log_error "forward.list 存在冲突：$proto_i/$lport_i 对源限制 $src_i 存在多条 DNAT 规则：${rules[$i]} | ${rules[$j]}"
                return 1
            fi

            if [[ -n "$src_i" && -n "$src_j" ]] && ipv4_cidrs_overlap "$src_i" "$src_j"; then
                if [[ "$rip_i:$rport_i" != "$rip_j:$rport_j" ]]; then
                    log_error "forward.list 存在重叠冲突：$proto_i/$lport_i 的源限制 $src_i 与 $src_j 重叠，但目标不同：${rules[$i]} | ${rules[$j]}"
                    return 1
                fi
            fi

            if [[ -z "$src_i" && -n "$src_j" && "$rip_i:$rport_i" != "$rip_j:$rport_j" ]]; then
                log_error "forward.list 存在遮蔽：无源限制规则在前，会覆盖后续同端口源限制规则：${rules[$i]} | ${rules[$j]}"
                return 1
            fi

            if [[ -n "$src_i" && -z "$src_j" && "$rip_i:$rport_i" != "$rip_j:$rport_j" ]]; then
                log_error "forward.list 存在重叠冲突：$proto_i/$lport_i 先匹配源限制 $src_i，随后又存在无源限制且目标不同的 DNAT 规则：${rules[$i]} | ${rules[$j]}"
                return 1
            fi
        done
    done

    return 0
}

generate_rules_file() {
    run_preflight_checks || return 1

    local outfile="$1"
    local include_runtime_ssh_rescue="${2:-yes}"
    local line proto port range src lport rip rport maxc raw_line
    local -a blocked_v4=() blocked_v6=()
    local -a allow_tcp_ports=() allow_udp_ports=()
    local -a block_tcp_ports=() block_udp_ports=()
    local -a allow_tcp_ranges=() allow_udp_ranges=()
    local -a forward_rules=() acl_rules=() ratelimit_rules=() connlimit_rules=()
    local -a auto_ssh_ports=()
    local wan_postrouting_expr=""
    local wan_match_expr=""
    local connlimit_present="no"
    local ping_v4_rate_compact="$(normalize_rate_value "$PING_V4_RATE")"
    local drop_log_rate_compact="$(normalize_rate_value "$DROP_LOG_RATE")"
    local counter_word
    local have_dnat_rules="no"

    counter_word="$(counter_stmt)"
    [[ -n "$WAN_IFACE" ]] && wan_postrouting_expr="oifname \"$WAN_IFACE\" "
    [[ -n "$WAN_IFACE" ]] && wan_match_expr="iifname \"$WAN_IFACE\" "

    while IFS= read -r line || [[ -n "$line" ]]; do
        local raw_line="$line"
        line="$(canonicalize_entry "$BLOCK_IP_FILE" "$line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "block_ip.list IP/网段格式无效：$raw_line"; return 1; }
            continue
        }
        if is_ipv6_value "$line"; then
            blocked_v6+=("$line")
        else
            blocked_v4+=("$line")
        fi
    done < "$BLOCK_IP_FILE"

    while IFS= read -r line || [[ -n "$line" ]]; do
        local raw_line="$line"
        line="$(canonicalize_entry "$ALLOW_FILE" "$line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "allow.list 格式无效：$raw_line"; return 1; }
            continue
        }
        read -r proto port <<< "$line"
        if [[ "$proto" == "tcp" ]]; then
            allow_tcp_ports+=("$port")
        else
            allow_udp_ports+=("$port")
        fi
    done < "$ALLOW_FILE"

    while IFS= read -r line || [[ -n "$line" ]]; do
        local raw_line="$line"
        line="$(canonicalize_entry "$BLOCK_PORT_FILE" "$line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "block_port.list 格式无效：$raw_line"; return 1; }
            continue
        }
        read -r proto port <<< "$line"
        if [[ "$proto" == "tcp" ]]; then
            block_tcp_ports+=("$port")
        else
            block_udp_ports+=("$port")
        fi
    done < "$BLOCK_PORT_FILE"

    while IFS= read -r line || [[ -n "$line" ]]; do
        local raw_line="$line"
        line="$(canonicalize_entry "$ALLOW_RANGE_FILE" "$line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "allow_range.list 格式无效：$raw_line"; return 1; }
            continue
        }
        read -r proto range <<< "$line"
        if [[ "$proto" == "tcp" ]]; then
            allow_tcp_ranges+=("$range")
        else
            allow_udp_ranges+=("$range")
        fi
    done < "$ALLOW_RANGE_FILE"

    if has_valid_entries "$CONNLIMIT_FILE"; then
        connlimit_present="yes"
        check_connlimit_support || return 1
    fi

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        line="$(canonicalize_entry "$FORWARD_FILE" "$raw_line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "forward.list 格式无效：$raw_line"; return 1; }
            continue
        }
        have_dnat_rules="yes"
        forward_rules+=("$line")
    done < "$FORWARD_FILE"

    if [[ "$include_runtime_ssh_rescue" == "yes" ]]; then
        mapfile -t auto_ssh_ports < <(get_auto_ssh_rescue_ports)
        if (( ${#auto_ssh_ports[@]} > 0 )); then
            allow_tcp_ports+=("${auto_ssh_ports[@]}")
            if (( ${#block_tcp_ports[@]} > 0 )); then
                local -a filtered_block_tcp_ports=()
                local block_port_item rescue_port keep_block
                for block_port_item in "${block_tcp_ports[@]}"; do
                    keep_block=1
                    for rescue_port in "${auto_ssh_ports[@]}"; do
                        if [[ "$block_port_item" == "$rescue_port" ]]; then
                            keep_block=0
                            break
                        fi
                    done
                    (( keep_block )) && filtered_block_tcp_ports+=("$block_port_item")
                done
                block_tcp_ports=("${filtered_block_tcp_ports[@]}")
            fi
        fi
    fi

    if (( ${#blocked_v4[@]} > 0 )); then
        mapfile -t blocked_v4 < <(collapse_ip_elements ipv4 "${blocked_v4[@]}")
    fi
    if (( ${#blocked_v6[@]} > 0 )); then
        mapfile -t blocked_v6 < <(collapse_ip_elements ipv6 "${blocked_v6[@]}")
    fi
    if (( ${#allow_tcp_ports[@]} > 0 )); then
        mapfile -t allow_tcp_ports < <(dedupe_scalar_array "${allow_tcp_ports[@]}")
    fi
    if (( ${#allow_udp_ports[@]} > 0 )); then
        mapfile -t allow_udp_ports < <(dedupe_scalar_array "${allow_udp_ports[@]}")
    fi
    if (( ${#block_tcp_ports[@]} > 0 )); then
        mapfile -t block_tcp_ports < <(dedupe_scalar_array "${block_tcp_ports[@]}")
    fi
    if (( ${#block_udp_ports[@]} > 0 )); then
        mapfile -t block_udp_ports < <(dedupe_scalar_array "${block_udp_ports[@]}")
    fi
    if (( ${#allow_tcp_ranges[@]} > 0 )); then
        mapfile -t allow_tcp_ranges < <(merge_port_ranges "${allow_tcp_ranges[@]}")
    fi
    if (( ${#allow_udp_ranges[@]} > 0 )); then
        mapfile -t allow_udp_ranges < <(merge_port_ranges "${allow_udp_ranges[@]}")
    fi
    if (( ${#forward_rules[@]} > 0 )); then
        mapfile -t forward_rules < <(dedupe_scalar_array "${forward_rules[@]}")
        validate_forward_rule_collisions "${forward_rules[@]}" || return 1
    fi

    cat > "$outfile" <<EOF_RULES
#!/usr/sbin/nft -f

table ip $TABLE_NAT {
    chain prerouting {
        type nat hook prerouting priority dstnat; policy accept;
EOF_RULES

    for line in "${forward_rules[@]}"; do
        src=""
        read -r proto lport rip rport src <<< "$line"
        if [[ -n "$src" ]]; then
            echo "        ${wan_match_expr}ip saddr $src $proto dport $lport ${counter_word}dnat to $rip:$rport" >> "$outfile"
        else
            echo "        ${wan_match_expr}$proto dport $lport ${counter_word}dnat to $rip:$rport" >> "$outfile"
        fi
    done

    cat >> "$outfile" <<EOF_RULES
    }

    chain postrouting {
        type nat hook postrouting priority srcnat; policy accept;
EOF_RULES

    if [[ "$have_dnat_rules" == "yes" ]]; then
        echo "        ${wan_postrouting_expr}ct status dnat ${counter_word}masquerade" >> "$outfile"
    fi

    cat >> "$outfile" <<EOF_RULES
    }
}

table inet $TABLE_FW {
EOF_RULES

    build_set_block "$outfile" "blocked_v4" "ipv4_addr" "interval" "${blocked_v4[@]}"
    build_set_block "$outfile" "blocked_v6" "ipv6_addr" "interval" "${blocked_v6[@]}"
    build_set_block "$outfile" "allow_tcp_ports" "inet_service" "" "${allow_tcp_ports[@]}"
    build_set_block "$outfile" "allow_udp_ports" "inet_service" "" "${allow_udp_ports[@]}"
    build_set_block "$outfile" "block_tcp_ports" "inet_service" "" "${block_tcp_ports[@]}"
    build_set_block "$outfile" "block_udp_ports" "inet_service" "" "${block_udp_ports[@]}"
    build_set_block "$outfile" "allow_tcp_ranges" "inet_service" "interval" "${allow_tcp_ranges[@]}"
    build_set_block "$outfile" "allow_udp_ranges" "inet_service" "interval" "${allow_udp_ranges[@]}"

    cat >> "$outfile" <<EOF_RULES

    chain trace_prerouting {
        type filter hook prerouting priority -301; policy accept;
EOF_RULES

    if [[ -n "$WAN_IFACE" ]]; then
        printf '        iifname "%s" tcp dport @block_tcp_ports %sdrop\n' "$WAN_IFACE" "$counter_word" >> "$outfile"
        printf '        iifname "%s" udp dport @block_udp_ports %sdrop\n' "$WAN_IFACE" "$counter_word" >> "$outfile"
    fi

    generate_trace_prerouting_rules "$outfile" || return 1

    cat >> "$outfile" <<EOF_RULES
    }

    chain input {
        type filter hook input priority filter; policy $INPUT_POLICY;
        ip saddr @blocked_v4 ${counter_word}drop
        ip6 saddr @blocked_v6 ${counter_word}drop
        ct state invalid ${counter_word}drop
        iifname "lo" accept
        tcp dport @block_tcp_ports ${counter_word}drop
        udp dport @block_udp_ports ${counter_word}drop
        icmp type { destination-unreachable, time-exceeded, parameter-problem } ${counter_word}accept
        icmpv6 type { destination-unreachable, packet-too-big, time-exceeded, parameter-problem } ${counter_word}accept
EOF_RULES

    if [[ "$ALLOW_PING_V4" == "yes" ]]; then
        echo "        icmp type echo-request limit rate $ping_v4_rate_compact ${counter_word}accept" >> "$outfile"
        echo "        icmp type echo-reply ${counter_word}accept" >> "$outfile"
    fi
    if [[ "$ALLOW_IPV6_ND" == "yes" ]]; then
        echo "        icmpv6 type { nd-neighbor-solicit, nd-neighbor-advert, nd-router-advert, nd-router-solicit } ${counter_word}accept" >> "$outfile"
    fi
    if [[ "$ALLOW_PING_V6" == "yes" ]]; then
        echo "        icmpv6 type { echo-request, echo-reply } ${counter_word}accept" >> "$outfile"
    fi


    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        line="$(canonicalize_entry "$RATELIMIT_FILE" "$raw_line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "ratelimit.list 格式无效：$raw_line"; return 1; }
            continue
        }
        ratelimit_rules+=("$line")
    done < "$RATELIMIT_FILE"

    if (( ${#ratelimit_rules[@]} > 0 )); then
        mapfile -t ratelimit_rules < <(dedupe_scalar_array "${ratelimit_rules[@]}")
    fi

    for line in "${ratelimit_rules[@]}"; do
        parse_ratelimit_line "$line" || { log_error "ratelimit.list 格式无效：$line"; return 1; }
        if [[ -n "$PARSED_RATE_BURST" ]]; then
            echo "        $PARSED_RATE_PROTO dport $PARSED_RATE_PORT limit rate over $PARSED_RATE_VALUE burst $PARSED_RATE_BURST_EMIT ${counter_word}drop" >> "$outfile"
        else
            echo "        $PARSED_RATE_PROTO dport $PARSED_RATE_PORT limit rate over $PARSED_RATE_VALUE ${counter_word}drop" >> "$outfile"
        fi
    done

    echo "        ct state vmap { established : accept, related : accept }" >> "$outfile"

    if [[ "$connlimit_present" == "yes" ]]; then
        while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
            line="$(canonicalize_entry "$CONNLIMIT_FILE" "$raw_line" 2>/dev/null || true)"
            [[ -z "$line" ]] && {
                raw_line="$(normalize_line "$raw_line")"
                [[ -n "$raw_line" ]] && { log_error "connlimit.list 格式无效：$raw_line"; return 1; }
                continue
            }
            connlimit_rules+=("$line")
        done < "$CONNLIMIT_FILE"

        if (( ${#connlimit_rules[@]} > 0 )); then
            mapfile -t connlimit_rules < <(dedupe_scalar_array "${connlimit_rules[@]}")
        fi

        for line in "${connlimit_rules[@]}"; do
            read -r proto port maxc <<< "$line"
            echo "        $proto dport $port ct count over $maxc ${counter_word}drop" >> "$outfile"
        done
    fi

    while IFS= read -r raw_line || [[ -n "$raw_line" ]]; do
        line="$(canonicalize_entry "$ALLOW_ACL_FILE" "$raw_line" 2>/dev/null || true)"
        [[ -z "$line" ]] && {
            raw_line="$(normalize_line "$raw_line")"
            [[ -n "$raw_line" ]] && { log_error "allow_acl.list 格式无效：$raw_line"; return 1; }
            continue
        }
        acl_rules+=("$line")
    done < "$ALLOW_ACL_FILE"

    if (( ${#acl_rules[@]} > 0 )); then
        mapfile -t acl_rules < <(dedupe_scalar_array "${acl_rules[@]}")
    fi

    for line in "${acl_rules[@]}"; do
        read -r proto port src <<< "$line"
        if is_ipv6_value "$src"; then
            echo "        ip6 saddr $src $proto dport $port ${counter_word}accept" >> "$outfile"
        else
            echo "        ip saddr $src $proto dport $port ${counter_word}accept" >> "$outfile"
        fi
    done

    cat >> "$outfile" <<EOF_RULES
        tcp dport @allow_tcp_ports ${counter_word}accept
        udp dport @allow_udp_ports ${counter_word}accept
        tcp dport @allow_tcp_ranges ${counter_word}accept
        udp dport @allow_udp_ranges ${counter_word}accept
EOF_RULES

    if [[ "$ENABLE_DROP_LOG" == "yes" && "$INPUT_POLICY" == "drop" ]]; then
        echo "        limit rate $drop_log_rate_compact log prefix \"NFT-IN-DROP: \" level warn" >> "$outfile"
    fi

    cat >> "$outfile" <<EOF_RULES
    }

    chain forward {
        type filter hook forward priority filter; policy $FORWARD_POLICY;
        ip saddr @blocked_v4 ${counter_word}drop
        ip6 saddr @blocked_v6 ${counter_word}drop
        ct state vmap { established : accept, related : accept, invalid : drop }
EOF_RULES

    for line in "${forward_rules[@]}"; do
        src=""
        read -r proto lport rip rport src <<< "$line"
        if [[ -n "$src" ]]; then
            echo "        ${wan_match_expr}ct status dnat ip saddr $src ip daddr $rip $proto dport $rport ${counter_word}accept" >> "$outfile"
        else
            echo "        ${wan_match_expr}ct status dnat ip daddr $rip $proto dport $rport ${counter_word}accept" >> "$outfile"
        fi
    done

    if [[ "$ENABLE_DROP_LOG" == "yes" && "$FORWARD_POLICY" == "drop" ]]; then
        echo "        limit rate $drop_log_rate_compact log prefix \"NFT-FWD-DROP: \" level warn" >> "$outfile"
    fi

    cat >> "$outfile" <<EOF_RULES
    }

    chain output {
        type filter hook output priority filter; policy $OUTPUT_POLICY;
    }
}
EOF_RULES
}

validate_render_only() {
    local tmp_file
    tmp_file="$(safe_mktemp_file nft-manager-preview.XXXXXX.nft)" || { log_error "无法创建临时文件。"; return 1; }

    if ! generate_rules_file "$tmp_file" no; then
        rm -f "$tmp_file"
        log_error "规则生成失败。"
        return 1
    fi

    if "$NFT_BIN" -c -f "$tmp_file"; then
        if ! atomic_install_file "$tmp_file" "$COMPILED_PREVIEW_FILE" 600; then
            rm -f "$tmp_file"
            log_error "规则校验通过，但无法写入预览文件：$COMPILED_PREVIEW_FILE"
            return 1
        fi
        rm -f "$tmp_file"
        log_ok "规则校验通过。预览文件：$COMPILED_PREVIEW_FILE"
        return 0
    else
        rm -f "$tmp_file"
        log_error "nft 语法校验失败。"
        return 1
    fi
}

apply_rules() {
    log_warn "正在生成、校验并应用规则..."
    warn_iptables_nat_conflict
    warn_auto_ssh_runtime_allow

    local tmp_file saved_tmp_file rollback_snap=""
    local rollback_snap_ready=0 sysctl_sync_ok=1
    local service_files_ok=1 service_runtime_ok=1 last_snapshot_updated=0

    tmp_file="$(safe_mktemp_file nft-manager.XXXXXX.nft)" || { log_error "无法创建临时文件。"; return 1; }
    saved_tmp_file="$(safe_mktemp_file nft-manager-saved.XXXXXX.nft)" || { rm -f "$tmp_file"; log_error "无法创建持久化临时文件。"; return 1; }

    rollback_snap="$(safe_mktemp_file nft-manager-rollback.XXXXXX.nft 2>/dev/null || true)"
    if [[ -n "$rollback_snap" ]]; then
        if capture_managed_snapshot_to_file "$rollback_snap"; then
            rollback_snap_ready=1
        else
            rm -f "$rollback_snap"
            rollback_snap=""
            log_warn "无法捕获切换前受管运行态快照；若本次应用失败，将退回到上一份已知受管运行态快照。"
        fi
    else
        log_warn "无法创建切换前受管运行态快照文件；若本次应用失败，将退回到上一份已知受管运行态快照。"
    fi

    if ! generate_rules_file "$tmp_file" yes; then
        rm -f "$tmp_file" "$saved_tmp_file" "$rollback_snap"
        log_error "规则生成失败。"
        return 1
    fi

    if ! generate_rules_file "$saved_tmp_file" no; then
        rm -f "$tmp_file" "$saved_tmp_file" "$rollback_snap"
        log_error "持久化规则生成失败。"
        return 1
    fi

    if ! "$NFT_BIN" -c -f "$tmp_file"; then
        rm -f "$tmp_file" "$saved_tmp_file" "$rollback_snap"
        log_error "nft 语法校验失败，未应用任何新规则。"
        return 1
    fi

    if ! "$NFT_BIN" -c -f "$saved_tmp_file"; then
        rm -f "$tmp_file" "$saved_tmp_file" "$rollback_snap"
        log_error "持久化 rules.nft 语法校验失败，未应用任何新规则。"
        return 1
    fi

    if ! drop_managed_tables_quiet; then
        rm -f "$tmp_file" "$saved_tmp_file" "$rollback_snap"
        log_error "无法清理当前受管表，已放弃应用新规则。"
        return 1
    fi

    if "$NFT_BIN" -f "$tmp_file"; then
        if ! atomic_install_file "$saved_tmp_file" "$NFT_RULE_FILE" 600; then
            rm -f "$tmp_file" "$saved_tmp_file"
            log_error "规则已写入运行态，但保存到 $NFT_RULE_FILE 失败；正在回滚到切换前受管运行态。"
            if (( rollback_snap_ready == 1 )); then
                if restore_managed_snapshot "$rollback_snap" >/dev/null 2>&1; then
                    sync_sysctl_from_snapshot "$rollback_snap" || log_warn "保存失败后的 sysctl 切换前快照恢复也失败了。"
                    mark_service_inactive_after_direct_runtime_restore
                    if ! grep -Eq '^[[:space:]]*table[[:space:]]+' "$rollback_snap" 2>/dev/null; then
                        log_warn "已回滚到本次切换前的空受管运行态。"
                    else
                        log_warn "已回滚到本次切换前的受管运行态。"
                    fi
                else
                    log_error "保存失败后回滚到切换前受管运行态也失败了，请立即检查当前 nft 运行态。"
                fi
            elif [[ -s "$LAST_ACTIVE_RULESET_FILE" ]]; then
                log_warn "无法使用切换前快照，尝试恢复上一份已知受管运行态快照..."
                if restore_managed_snapshot "$LAST_ACTIVE_RULESET_FILE" >/dev/null 2>&1; then
                    sync_sysctl_from_snapshot "$LAST_ACTIVE_RULESET_FILE" || log_warn "保存失败后的 sysctl 已知快照恢复也失败了。"
                    mark_service_inactive_after_direct_runtime_restore
                    if ! grep -Eq '^[[:space:]]*table[[:space:]]+' "$LAST_ACTIVE_RULESET_FILE" 2>/dev/null; then
                        log_warn "已回滚到上一份已知空受管运行态快照。"
                    else
                        log_warn "已回滚到上一份已知受管运行态快照。"
                    fi
                else
                    log_error "保存失败后回滚到上一份已知受管运行态快照也失败了，请立即检查当前 nft 运行态。"
                fi
            fi
            rm -f "$rollback_snap"
            return 1
        fi
        rm -f "$tmp_file" "$saved_tmp_file"

        if ! write_sysctl; then
            sysctl_sync_ok=0
        fi

        if backup_active_ruleset; then
            last_snapshot_updated=1
        else
            log_warn "规则已应用，但无法刷新“最近一次受管运行态快照”；菜单 20 可能仍恢复到较旧版本。"
        fi

        if ! write_service; then
            service_files_ok=0
            service_runtime_ok=0
            mark_service_inactive_after_direct_runtime_restore
            log_warn "规则已保存，但 systemd 持久化文件刷新失败；重启后可能无法自动恢复最新规则。"
        fi
        if (( service_files_ok == 1 )); then
            if ! refresh_service_runtime_state; then
                service_runtime_ok=0
            fi
        else
            log_warn "已跳过刷新 systemd 管理状态，避免继续使用旧的 service/loader 定义。"
        fi

        rm -f "$rollback_snap"

        if (( sysctl_sync_ok == 1 )); then
            case "$SYSCTL_LAST_SYNC_MODE" in
                full)
                    if (( service_runtime_ok == 1 )); then
                        if (( last_snapshot_updated == 1 )); then
                            log_ok "规则已成功应用。"
                        else
                            log_warn "规则已成功应用，但最近一次运行态快照未能刷新。"
                        fi
                    else
                        if (( last_snapshot_updated == 1 )); then
                            log_warn "规则已成功应用，但 systemd 管理状态刷新失败；状态页请结合“受管表运行态”一起判断。"
                        else
                            log_warn "规则已成功应用，但 systemd 管理状态刷新失败，且最近一次运行态快照未能刷新。"
                        fi
                    fi
                    ;;
                runtime-fallback)
                    if (( last_snapshot_updated == 1 )); then
                        log_warn "规则已应用，sysctl 当前运行态已同步，但 sysctl --system 失败并已回退到直接写入运行态；建议检查系统其他 sysctl 配置。"
                    else
                        log_warn "规则已应用，sysctl 当前运行态已同步，但 sysctl --system 失败并已回退到直接写入运行态；同时最近一次运行态快照未能刷新。"
                    fi
                    ;;
                runtime-only)
                    if (( last_snapshot_updated == 1 )); then
                        log_warn "规则已应用，当前运行态已同步，但 sysctl 持久化文件未能成功更新；重启后 forwarding 设置可能无法保留。"
                    else
                        log_warn "规则已应用，当前运行态已同步，但 sysctl 持久化文件未能成功更新，且最近一次运行态快照未能刷新；重启后 forwarding 设置可能无法保留。"
                    fi
                    ;;
                *)
                    if (( service_runtime_ok == 1 )); then
                        if (( last_snapshot_updated == 1 )); then
                            log_ok "规则已成功应用。"
                        else
                            log_warn "规则已成功应用，但最近一次运行态快照未能刷新。"
                        fi
                    else
                        if (( last_snapshot_updated == 1 )); then
                            log_warn "规则已成功应用，但 systemd 管理状态刷新失败；状态页请结合“受管表运行态”一起判断。"
                        else
                            log_warn "规则已成功应用，但 systemd 管理状态刷新失败，且最近一次运行态快照未能刷新。"
                        fi
                    fi
                    ;;
            esac
        else
            if (( last_snapshot_updated == 1 )); then
                log_warn "规则已应用，但 sysctl/forwarding 同步失败，请手动检查当前运行态与 $SYSCTL_FILE。"
            else
                log_warn "规则已应用，但 sysctl/forwarding 同步失败，且最近一次运行态快照未能刷新；请手动检查当前运行态与 $SYSCTL_FILE。"
            fi
        fi
        return 0
    else
        rm -f "$tmp_file" "$saved_tmp_file"
        log_error "规则应用失败。"
        if (( rollback_snap_ready == 1 )); then
            log_warn "尝试回滚到本次切换前的受管运行态..."
            if restore_managed_snapshot "$rollback_snap" >/dev/null 2>&1; then
                sync_sysctl_from_snapshot "$rollback_snap" || log_warn "应用失败后的 sysctl 切换前快照恢复也失败了。"
                mark_service_inactive_after_direct_runtime_restore
                if ! grep -Eq '^[[:space:]]*table[[:space:]]+' "$rollback_snap" 2>/dev/null; then
                    log_warn "已回滚到本次切换前的空受管运行态。"
                else
                    log_warn "已回滚到本次切换前的受管运行态。"
                fi
            else
                log_error "应用失败后回滚到切换前受管运行态也失败了，请立即检查当前 nft 运行态。"
            fi
        elif [[ -s "$LAST_ACTIVE_RULESET_FILE" ]]; then
            log_warn "无法使用切换前快照，尝试恢复上一份已知受管运行态快照..."
            if restore_managed_snapshot "$LAST_ACTIVE_RULESET_FILE" >/dev/null 2>&1; then
                sync_sysctl_from_snapshot "$LAST_ACTIVE_RULESET_FILE" || log_warn "应用失败后的 sysctl 已知快照恢复也失败了。"
                mark_service_inactive_after_direct_runtime_restore
                if ! grep -Eq '^[[:space:]]*table[[:space:]]+' "$LAST_ACTIVE_RULESET_FILE" 2>/dev/null; then
                    log_warn "已回滚到上一份已知空受管运行态快照。"
                else
                    log_warn "已回滚到上一份已知受管运行态快照。"
                fi
            else
                log_error "应用失败后恢复上一份已知受管运行态快照也失败了，请立即检查当前 nft 运行态。"
            fi
        fi
        rm -f "$rollback_snap"
        return 1
    fi
}

backup_rules() {
    if ! mkdir -p "$BACKUP_DIR"; then
        log_error "无法创建备份目录：$BACKUP_DIR"
        return 1
    fi
    chmod 700 "$BACKUP_DIR" 2>/dev/null || true
    local backup_file tmp_backup old_umask tar_rc=1
    backup_file="$(unique_backup_file_path nft_backup)"
    tmp_backup="$(mktemp "$BACKUP_DIR/.tmp.nft_backup.XXXXXX.tar.gz")" || {
        log_error "无法创建临时备份文件：$BACKUP_DIR"
        return 1
    }

    if [[ -d "$CONF_DIR" ]]; then
        old_umask="$(umask)"
        umask 077
        if create_config_backup_archive "$tmp_backup"; then
            tar_rc=0
        fi
        umask "$old_umask"
        if (( tar_rc == 0 )) && mv -f "$tmp_backup" "$backup_file"; then
            [ -f "$backup_file" ] && chmod 600 "$backup_file" 2>/dev/null || true
            log_ok "✅ 配置已成功备份至：$backup_file"
            return 0
        else
            rm -f "$tmp_backup" "$backup_file"
            log_error "配置备份失败，请检查目录权限、磁盘空间或 tar 命令返回值。"
            return 1
        fi
    else
        rm -f "$tmp_backup"
        log_error "配置目录不存在，无可备份内容。"
        return 1
    fi
}


restore_rules() {
    local backups=()
    local choice i file selected tmp_restore src_dir old_conf_snap rc=1

    if ! validate_runtime_managed_paths_safe; then
        log_error "受管配置文件或目录当前不安全，已拒绝执行恢复。"
        return 1
    fi

    if [[ ! -d "$BACKUP_DIR" ]]; then
        log_warn "没有找到任何备份文件。"
        return 1
    fi

    while IFS= read -r file; do
        [[ -n "$file" ]] || continue
        [[ "$file" == *"/runtime/"* ]] && continue
        [[ "$(basename "$file")" == nft_backup_auto_before_restore_* ]] && continue
        if backup_file_is_usable "$file"; then
            backups+=("$file")
        else
            log_warn "已跳过损坏或不完整的备份文件：$(basename "$file")"
        fi
    done < <(ls -1t -- "$BACKUP_DIR"/nft_backup_*.tar.gz 2>/dev/null || true)

    if [[ ${#backups[@]} -eq 0 ]]; then
        log_warn "没有找到任何备份文件。"
        return 1
    fi

    echo -e "${CYAN}--- 可用的配置备份列表 ---${PLAIN}"
    for i in "${!backups[@]}"; do
        printf '%d. %s
' "$((i + 1))" "$(basename "${backups[$i]}")"
    done

    read -r -p "请输入要恢复的备份序号 (输入 0 取消): " choice
    if [[ "$choice" == "0" ]]; then
        log_ok "已取消恢复。"
        return 0
    fi

    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#backups[@]} )); then
        log_error "无效的序号！"
        return 1
    fi

    selected="${backups[$((choice - 1))]}"
    tmp_restore="$(safe_mktemp_dir nft-manager-restore.XXXXXX)" || {
        log_error "无法创建临时恢复目录。"
        return 1
    }
    old_conf_snap="$(make_dir_snapshot "$CONF_DIR")" || {
        rm -rf "$tmp_restore"
        log_error "无法创建当前配置快照，已取消恢复。"
        return 1
    }

    if ! backup_file_is_usable "$selected"; then
        rm -rf "$tmp_restore" "$old_conf_snap"
        log_error "恢复失败：备份文件结构不安全或缺少核心配置文件。"
        return 1
    fi

    if ! extract_backup_archive_to_dir "$selected" "$tmp_restore"; then
        rm -rf "$tmp_restore" "$old_conf_snap"
        log_error "恢复失败，请检查备份文件。"
        return 1
    fi

    if [[ -d "$tmp_restore/$(basename "$CONF_DIR")" ]]; then
        src_dir="$tmp_restore/$(basename "$CONF_DIR")"
    elif [[ -d "$tmp_restore$(dirname "$CONF_DIR")/$(basename "$CONF_DIR")" ]]; then
        src_dir="$tmp_restore$(dirname "$CONF_DIR")/$(basename "$CONF_DIR")"
    elif [[ -d "$tmp_restore/nft_manager" ]]; then
        src_dir="$tmp_restore/nft_manager"
    elif [[ -d "$tmp_restore/etc/nft_manager" ]]; then
        src_dir="$tmp_restore/etc/nft_manager"
    else
        rm -rf "$tmp_restore" "$old_conf_snap"
        log_error "备份内容不完整：未找到 nft_manager 目录。"
        return 1
    fi

    while IFS= read -r required; do
        [[ -n "$required" ]] || continue
        if [[ ! -f "$src_dir/$required" ]]; then
            rm -rf "$tmp_restore" "$old_conf_snap"
            log_error "备份内容不完整：缺少核心文件 $required。"
            return 1
        fi
    done < <(restore_required_files)

    if ! restored_tree_is_safe "$src_dir"; then
        rm -rf "$tmp_restore" "$old_conf_snap"
        log_error "恢复失败：备份内容包含符号链接或特殊文件，已拒绝导入。"
        return 1
    fi

    log_warn "正在恢复备份..."
    if [[ -d "$CONF_DIR" ]]; then
        local auto_backup tmp_auto_backup old_umask
        auto_backup="$(unique_backup_file_path nft_backup_auto_before_restore)"
        tmp_auto_backup="$(mktemp "$BACKUP_DIR/.tmp.nft_backup_auto_before_restore.XXXXXX.tar.gz")" || tmp_auto_backup=""
        old_umask="$(umask)"
        umask 077
        if [[ -n "$tmp_auto_backup" ]] && create_config_backup_archive "$tmp_auto_backup" && mv -f "$tmp_auto_backup" "$auto_backup"; then
            [ -f "$auto_backup" ] && chmod 600 "$auto_backup" 2>/dev/null || true
        else
            [[ -n "$tmp_auto_backup" ]] && rm -f "$tmp_auto_backup"
            rm -f "$auto_backup"
            log_warn "恢复前自动备份失败，继续执行恢复；建议手动检查备份目录权限或磁盘空间。"
        fi
        umask "$old_umask"
    fi

    if ! rm -rf "$CONF_DIR"; then
        log_error "无法清理当前配置目录：$CONF_DIR"
        if restore_dir_from_snapshot "$CONF_DIR" "$old_conf_snap"; then
            log_warn "已回滚到恢复前配置目录。"
        else
            log_error "配置目录回滚失败，请手动检查：$CONF_DIR"
        fi
        rm -rf "$tmp_restore" "$old_conf_snap"
        return 1
    fi
    if ! mkdir -p "$(dirname "$CONF_DIR")"; then
        log_error "无法创建配置目录父路径：$(dirname "$CONF_DIR")"
        if restore_dir_from_snapshot "$CONF_DIR" "$old_conf_snap"; then
            log_warn "已回滚到恢复前配置目录。"
        else
            log_error "配置目录回滚失败，请手动检查：$CONF_DIR"
        fi
        rm -rf "$tmp_restore" "$old_conf_snap"
        return 1
    fi
    if ! restore_conf_tree_from_backup "$src_dir" "$CONF_DIR"; then
        log_error "恢复配置目录失败，正在回滚到恢复前状态..."
        if restore_dir_from_snapshot "$CONF_DIR" "$old_conf_snap"; then
            log_warn "已回滚到恢复前配置目录。"
        else
            log_error "配置目录回滚失败，请手动检查：$CONF_DIR"
        fi
        rm -rf "$tmp_restore" "$old_conf_snap"
        return 1
    fi
    rm -rf "$tmp_restore"

    if ! ensure_dirs; then
        log_error "恢复后的配置目录初始化失败，正在回滚到恢复前配置..."
        if restore_dir_from_snapshot "$CONF_DIR" "$old_conf_snap"; then
            log_warn "已回滚到恢复前配置目录。"
        else
            log_error "配置目录回滚失败，请手动检查：$CONF_DIR"
        fi
        rm -rf "$old_conf_snap"
        return 1
    fi
    if ! write_service; then
        log_warn "恢复后的 systemd 持久化文件更新失败；本次恢复即使成功，重启后也可能无法自动恢复规则。"
    fi

    log_warn "配置目录已恢复，正在重新应用规则..."
    if apply_rules; then
        rm -rf "$old_conf_snap"
        log_ok "✅ 配置恢复成功。"
        return 0
    fi

    log_error "恢复后的规则应用失败，正在回滚到恢复前配置..."
    if restore_dir_from_snapshot "$CONF_DIR" "$old_conf_snap"; then
        if ! ensure_dirs; then
            log_error "回滚后的配置目录初始化失败，请手动检查：$CONF_DIR"
            rm -rf "$old_conf_snap"
            return 1
        fi
        if ! write_service; then
            log_warn "回滚后的 systemd 持久化文件更新失败；请手动检查：$SERVICE_FILE / $LOADER_FILE"
        fi
        if apply_rules; then
            log_warn "已回滚到恢复前配置与规则状态。"
        else
            log_error "配置目录已回滚，但重新应用旧配置失败，请手动检查。"
        fi
    else
        log_error "配置目录回滚失败，请手动检查：$CONF_DIR"
    fi

    rm -rf "$old_conf_snap"
    return 1
}

