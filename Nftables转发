    else
        rm -f "$snap"
        log_info "规则已存在，未修改 NAT 转发列表。"
    fi
}


enable_nftrace() {
    local proto port src rc changed=0 snap
    read -r -p "请输入协议 (tcp/udp，默认 tcp): " proto
    [[ -z "$proto" ]] && proto="tcp"
    validate_proto_rule "$proto" || { log_error "协议输入无效。"; return; }

    read -r -p "请输入要追踪的端口: " port
    validate_port "$port" || { log_error "端口号无效。"; return; }

    read -r -p "源地址限制 (可留空): " src
    src="$(trim "$src")"
    if [[ -n "$src" ]]; then
        validate_ip_or_cidr "$src" || { log_error "源地址格式无效。"; return; }
    fi

    snap="$(make_file_snapshot "$TRACE_FILE")" || { log_error "无法创建文件快照，已取消写入。"; return; }
    append_unique_line "$proto $port${src:+ $src}" "$TRACE_FILE"; rc=$?
    (( rc == 1 )) && { rm -f "$snap"; return; }
    (( rc == 0 )) && changed=1
    if (( changed )); then
        log_info "另开一个终端执行：nft monitor trace"
        apply_with_file_rollback "$TRACE_FILE" "$snap" "规则应用失败" "已启用 prerouting nftrace 调试规则。" || return
    else
        rm -f "$snap"
        log_info "规则已存在，未修改 nftrace 列表。"
    fi
}


clear_nftrace() {
    local snap
    if [[ ! -s "$TRACE_FILE" ]]; then
        log_info "nftrace 调试规则文件本来就是空的，已跳过重新应用。"
        return 0
    fi
    snap="$(make_file_snapshot "$TRACE_FILE")" || { log_error "无法创建文件快照，已取消清空。"; return 1; }
    if ! atomic_rewrite_file_from_stdin "$TRACE_FILE" 600 <<'EOF_NFTMGR_EMPTY'
EOF_NFTMGR_EMPTY
    then
        rm -f "$snap"
        log_error "无法原子清空 $TRACE_FILE"
        return 1
    fi
    apply_with_file_rollback "$TRACE_FILE" "$snap" "清空 nftrace 调试规则失败" "已清空 nftrace 调试规则。" || return 1
    return 0
}


