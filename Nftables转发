#!/bin/bash
# nftables 网关管理脚本 Ultimate Fixed v5.17

set -u
set -o pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
PLAIN='\033[0m'

CONF_DIR="/etc/nft_manager"
BACKUP_DIR="/etc/nft_manager_backups"
RUNTIME_DIR="$BACKUP_DIR/runtime"

ALLOW_FILE="$CONF_DIR/allow.list"
ALLOW_RANGE_FILE="$CONF_DIR/allow_range.list"
ALLOW_ACL_FILE="$CONF_DIR/allow_acl.list"
FORWARD_FILE="$CONF_DIR/forward.list"
BLOCK_IP_FILE="$CONF_DIR/block_ip.list"
BLOCK_PORT_FILE="$CONF_DIR/block_port.list"
RATELIMIT_FILE="$CONF_DIR/ratelimit.list"
CONNLIMIT_FILE="$CONF_DIR/connlimit.list"
TRACE_FILE="$CONF_DIR/trace.list"
SETTINGS_FILE="$CONF_DIR/settings.conf"
NFT_RULE_FILE="$CONF_DIR/rules.nft"
COMPILED_PREVIEW_FILE="$CONF_DIR/rules.preview.nft"
LAST_ACTIVE_RULESET_FILE="$RUNTIME_DIR/last_active_ruleset.nft"
SYSCTL_FILE="/etc/sysctl.d/99-nft-manager.conf"
SERVICE_FILE="/etc/systemd/system/nft-manager.service"
SERVICE_WANTS_LINK="/etc/systemd/system/multi-user.target.wants/nft-manager.service"
LOADER_FILE="$CONF_DIR/load_saved_rules.sh"
LOCK_FILE="/run/nft_manager.lock"
LOCK_DIR="${LOCK_FILE}.d"

TABLE_NAT="custom_nat"
TABLE_FW="custom_fw"

INPUT_POLICY="drop"
FORWARD_POLICY="drop"
OUTPUT_POLICY="accept"
ENABLE_DROP_LOG="no"
DROP_LOG_RATE="10/second"
WAN_IFACE=""
AUTO_OPEN_SSH_PORT="yes"
ALLOW_PING_V4="yes"
PING_V4_RATE="5/second"
ALLOW_PING_V6="yes"
ALLOW_IPV6_ND="yes"
ENABLE_IPV6_FORWARD="no"
WARN_IPTABLES_NAT_CONFLICT="yes"
ENABLE_COUNTERS="yes"
SYSCTL_LAST_SYNC_MODE="unknown"

ACTIVE_LINE_MAP=()
ACTIVE_INVALID_MAP=()
NFT_BIN="$(command -v nft 2>/dev/null || true)"

[[ ${EUID:-$(id -u)} -ne 0 ]] && echo -e "${RED}错误：请使用 root 用户运行此脚本！${PLAIN}" && exit 1

LOCK_FALLBACK_HELD=0
pid_is_running() {
    local pid="$1"
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    kill -0 "$pid" >/dev/null 2>&1
}

read_pid_starttime() {
    local pid="$1" stat_line rest
    local -a stat_fields=()
    [[ "$pid" =~ ^[0-9]+$ ]] || return 1
    [[ -r "/proc/$pid/stat" ]] || return 1
    stat_line="$(cat "/proc/$pid/stat" 2>/dev/null || true)"
    [[ -n "$stat_line" && "$stat_line" == *") "* ]] || return 1
    rest="${stat_line##*) }"
    read -r -a stat_fields <<< "$rest"
    (( ${#stat_fields[@]} >= 20 )) || return 1
    printf '%s
' "${stat_fields[19]}"
}

write_lock_owner_info() {
    local pid="$1" starttime=""
    printf '%s
' "$pid" > "$LOCK_DIR/pid" 2>/dev/null || true
    starttime="$(read_pid_starttime "$pid" 2>/dev/null || true)"
    if [[ -n "$starttime" ]]; then
        printf '%s
' "$starttime" > "$LOCK_DIR/starttime" 2>/dev/null || true
    else
        rm -f "$LOCK_DIR/starttime" 2>/dev/null || true
    fi
}

lock_owner_is_active() {
    local pid="$1" recorded_start="$2" current_start=""
    pid_is_running "$pid" || return 1
    if [[ -n "$recorded_start" ]]; then
        current_start="$(read_pid_starttime "$pid" 2>/dev/null || true)"
        [[ -n "$current_start" && "$current_start" == "$recorded_start" ]] || return 1
    fi
    return 0
}

acquire_global_lock() {
    local stale_pid="" stale_start=""

    if command -v flock >/dev/null 2>&1; then
        mkdir -p "$(dirname "$LOCK_FILE")" 2>/dev/null || true
        if [[ -L "$LOCK_FILE" || ( -e "$LOCK_FILE" && ! -f "$LOCK_FILE" ) ]]; then
            return 1
        fi
        exec 9>"$LOCK_FILE"
        flock -n 9
        return $?
    fi

    mkdir -p "$(dirname "$LOCK_DIR")" 2>/dev/null || true
    if [[ -L "$LOCK_DIR" || ( -e "$LOCK_DIR" && ! -d "$LOCK_DIR" ) ]]; then
        return 1
    fi
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        LOCK_FALLBACK_HELD=1
        write_lock_owner_info "$$"
        trap 'if [[ "${LOCK_FALLBACK_HELD:-0}" == "1" ]]; then rm -rf "$LOCK_DIR"; fi' EXIT
        return 0
    fi

    stale_pid="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
    stale_start="$(cat "$LOCK_DIR/starttime" 2>/dev/null || true)"
    if [[ -n "$stale_pid" ]] && ! lock_owner_is_active "$stale_pid" "$stale_start"; then
        rm -rf "$LOCK_DIR" 2>/dev/null || true
        if mkdir "$LOCK_DIR" 2>/dev/null; then
            LOCK_FALLBACK_HELD=1
            write_lock_owner_info "$$"
            trap 'if [[ "${LOCK_FALLBACK_HELD:-0}" == "1" ]]; then rm -rf "$LOCK_DIR"; fi' EXIT
            return 0
        fi
    fi
    return 1
}

acquire_global_lock || { echo -e "${RED}错误：已有另一个 nft_manager 实例在运行。${PLAIN}"; exit 1; }

log_info()  { echo -e "${CYAN}$*${PLAIN}"; }
log_warn()  { echo -e "${YELLOW}$*${PLAIN}"; }
log_ok()    { echo -e "${GREEN}$*${PLAIN}"; }
log_error() { echo -e "${RED}$*${PLAIN}"; }

unique_backup_file_path() {
    local prefix="$1" ts candidate
    while true; do
        ts="$(date +"%Y%m%d_%H%M%S" 2>/dev/null || echo unknown_time)"
        candidate="$BACKUP_DIR/${prefix}_${ts}_${$}_${RANDOM}.tar.gz"
        [[ ! -e "$candidate" ]] && { printf '%s' "$candidate"; return 0; }
    done
}

restore_required_files() {
    cat <<'EOF_REQUIRED'
settings.conf
allow.list
allow_range.list
allow_acl.list
forward.list
block_ip.list
block_port.list
ratelimit.list
connlimit.list
trace.list
EOF_REQUIRED
}

restore_optional_files() {
    return 0
}

backup_included_files() {
    restore_required_files
}

managed_source_file_is_plain() {
    local path="$1"
    [[ -f "$path" && ! -L "$path" ]]
}

validate_managed_source_files_safe() {
    local name path
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        path="$CONF_DIR/$name"
        [[ -e "$path" || -L "$path" ]] || continue
        if ! managed_source_file_is_plain "$path"; then
            log_error "受管源配置文件必须是普通文件，不能是符号链接或特殊文件：$path"
            return 1
        fi
    done < <(backup_included_files)
    return 0
}

validate_runtime_managed_paths_safe() {
    validate_managed_directories_safe || return 1
    validate_managed_source_files_safe || return 1
    return 0
}

managed_dir_is_plain() {
    local path="$1"
    [[ -d "$path" && ! -L "$path" ]]
}

managed_dir_path_is_safe_before_create() {
    local path="$1"
    if [[ -L "$path" ]]; then
        log_error "受管目录不能是符号链接：$path"
        return 1
    fi
    if [[ -e "$path" && ! -d "$path" ]]; then
        log_error "受管目录路径已被非目录文件占用：$path"
        return 1
    fi
    return 0
}

validate_managed_directories_safe() {
    local path
    for path in "$CONF_DIR" "$BACKUP_DIR" "$RUNTIME_DIR"; do
        managed_dir_path_is_safe_before_create "$path" || return 1
        [[ -e "$path" ]] || continue
        if ! managed_dir_is_plain "$path"; then
            log_error "受管目录必须是真实目录，不能是符号链接或特殊文件：$path"
            return 1
        fi
    done
    return 0
}

create_config_backup_archive() {
    local archive="$1"
    local stage_dir stage_root name

    [[ -n "$archive" ]] || return 1
    [[ -d "$CONF_DIR" ]] || return 1
    validate_managed_directories_safe || return 1
    validate_managed_source_files_safe || return 1

    stage_dir="$(safe_mktemp_dir nft-manager-backup.XXXXXX)" || return 1
    stage_root="$stage_dir/$(basename "$CONF_DIR")"

    mkdir -p "$stage_root" || { rm -rf "$stage_dir"; return 1; }

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        managed_source_file_is_plain "$CONF_DIR/$name" || { rm -rf "$stage_dir"; return 1; }
        cp -f -- "$CONF_DIR/$name" "$stage_root/$name" || { rm -rf "$stage_dir"; return 1; }
        chmod 600 "$stage_root/$name" 2>/dev/null || true
    done < <(backup_included_files)

    if ! tar -czf "$archive" -C "$stage_dir" "$(basename "$CONF_DIR")" 2>/dev/null; then
        rm -rf "$stage_dir"
        return 1
    fi

    rm -rf "$stage_dir"
    return 0
}

locate_backup_member_path() {
    local archive="$1" rel="$2" entry normalized
    local conf_base rel_conf count=0 found="" found_archive=""

    BACKUP_MEMBER_FOUND=""
    BACKUP_MEMBER_ARCHIVE_PATH=""
    [[ -f "$archive" && -n "$rel" ]] || return 2

    conf_base="$(basename "$CONF_DIR")"
    rel_conf="${CONF_DIR#/}"

    while IFS= read -r entry; do
        [[ -n "$entry" ]] || continue
        normalized="${entry#./}"
        case "$normalized" in
            "$conf_base/$rel"|"$rel_conf/$rel")
                count=$((count + 1))
                found="$normalized"
                found_archive="$entry"
                ;;
        esac
    done < <(tar -tzf "$archive" 2>/dev/null)

    if (( count == 0 )); then
        return 1
    fi
    if (( count > 1 )); then
        return 2
    fi

    BACKUP_MEMBER_FOUND="$found"
    BACKUP_MEMBER_ARCHIVE_PATH="$found_archive"
    return 0
}

backup_member_is_plain_file() {
    local archive="$1" member="$2" first_char="" target

    [[ -f "$archive" && -n "$member" ]] || return 1
    target="${member#./}"
    first_char="$(tar -tvzf "$archive" 2>/dev/null | awk -v target="$target" '
        {
            path = $NF
            sub(/^\.\//, "", path)
            if (path == target) {
                print substr($0, 1, 1)
                found = 1
                exit
            }
        }
        END {
            if (!found) exit 1
        }
    ')" || return 1
    [[ "$first_char" == '-' ]]
}

extract_backup_member_to_tree() {
    local archive="$1" archive_member="$2" output_rel="$3" dst_root="$4"
    local out_path out_dir tmp_out

    [[ -f "$archive" && -n "$archive_member" && -n "$output_rel" && -d "$dst_root" ]] || return 1
    backup_member_is_plain_file "$archive" "$archive_member" || return 1

    out_path="$dst_root/$output_rel"
    out_dir="$(dirname "$out_path")"
    mkdir -p "$out_dir" || return 1

    tmp_out="$(mktemp "$out_dir/.tmp.$(basename "$out_path").XXXXXX")" || return 1
    if ! tar -xOf "$archive" "$archive_member" > "$tmp_out" 2>/dev/null; then
        rm -f "$tmp_out"
        return 1
    fi
    chmod 600 "$tmp_out" 2>/dev/null || true
    if ! mv -f "$tmp_out" "$out_path"; then
        rm -f "$tmp_out"
        return 1
    fi
    return 0
}

extract_backup_archive_to_dir() {
    local file="$1" dst="$2" name rc
    [[ -f "$file" && -d "$dst" ]] || return 1

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        locate_backup_member_path "$file" "$name"
        rc=$?
        (( rc == 0 )) || return 1
        extract_backup_member_to_tree "$file" "$BACKUP_MEMBER_ARCHIVE_PATH" "$BACKUP_MEMBER_FOUND" "$dst" || return 1
    done < <(restore_required_files)

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        locate_backup_member_path "$file" "$name"
        rc=$?
        if (( rc == 1 )); then
            continue
        fi
        (( rc == 0 )) || return 1
        extract_backup_member_to_tree "$file" "$BACKUP_MEMBER_ARCHIVE_PATH" "$BACKUP_MEMBER_FOUND" "$dst" || return 1
    done < <(restore_optional_files)

    return 0
}

backup_file_is_safe() {
    local file="$1" entry list_out name rc
    [[ -f "$file" && -s "$file" ]] || return 1

    list_out="$(tar -tzf "$file" 2>/dev/null)" || return 1

    while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        case "$entry" in
            /*) return 1 ;;
            *"../"*|"../"|*"/.."|"..") return 1 ;;
        esac
    done <<< "$list_out"

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        locate_backup_member_path "$file" "$name"
        rc=$?
        (( rc == 0 )) || return 1
        backup_member_is_plain_file "$file" "$BACKUP_MEMBER_ARCHIVE_PATH" || return 1
    done < <(restore_required_files)

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        locate_backup_member_path "$file" "$name"
        rc=$?
        if (( rc == 1 )); then
            continue
        fi
        (( rc == 0 )) || return 1
        backup_member_is_plain_file "$file" "$BACKUP_MEMBER_ARCHIVE_PATH" || return 1
    done < <(restore_optional_files)

    return 0
}

restored_tree_is_safe() {
    local dir="$1"
    [[ -d "$dir" ]] || return 1
    if find "$dir" ! -type d ! -type f -print -quit 2>/dev/null | grep -q .; then
        return 1
    fi
    return 0
}

restore_conf_tree_from_backup() {
    local src_dir="$1" dst_dir="$2" name path rel known extra_found=0
    local had_nullglob=0 had_dotglob=0
    local -a allowed_names=()

    [[ -d "$src_dir" ]] || return 1
    mkdir -p "$dst_dir" || return 1

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        allowed_names+=("$name")
    done < <(restore_required_files)
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        allowed_names+=("$name")
    done < <(restore_optional_files)

    shopt -q nullglob && had_nullglob=1
    shopt -q dotglob && had_dotglob=1
    shopt -s nullglob dotglob

    for path in "$src_dir"/*; do
        [[ -e "$path" ]] || continue
        rel="$(basename "$path")"
        known=0
        for name in "${allowed_names[@]}"; do
            if [[ "$rel" == "$name" ]]; then
                known=1
                break
            fi
        done
        if (( known == 0 )); then
            extra_found=1
            continue
        fi
        if [[ ! -f "$path" ]]; then
            (( had_nullglob == 1 )) || shopt -u nullglob
            (( had_dotglob == 1 )) || shopt -u dotglob
            return 1
        fi
        cp -f -- "$path" "$dst_dir/$rel" || {
            (( had_nullglob == 1 )) || shopt -u nullglob
            (( had_dotglob == 1 )) || shopt -u dotglob
            return 1
        }
    done

    (( had_nullglob == 1 )) || shopt -u nullglob
    (( had_dotglob == 1 )) || shopt -u dotglob

    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        [[ -f "$dst_dir/$name" ]] || return 1
    done < <(restore_required_files)

    if (( extra_found == 1 )); then
        log_warn "备份中存在未受管额外文件；恢复时已自动忽略。"
    fi

    return 0
}

backup_file_is_usable() {
    local file="$1" conf_base rel_conf required rel1 rel2 list_out entry found_root=0 found_required=0
    [[ -f "$file" && -s "$file" ]] || return 1

    backup_file_is_safe "$file" || return 1

    conf_base="$(basename "$CONF_DIR")"
    rel_conf="${CONF_DIR#/}"
    list_out="$(tar -tzf "$file" 2>/dev/null)" || return 1

    while IFS= read -r entry; do
        [[ -n "$entry" ]] || continue
        case "$entry" in
            "$conf_base"/*|./"$conf_base"/*|"$rel_conf"/*|./"$rel_conf"/*)
                found_root=1
                break
                ;;
        esac
    done <<< "$list_out"
    (( found_root == 1 )) || return 1

    while IFS= read -r required; do
        [[ -n "$required" ]] || continue
        rel1="${conf_base}/${required}"
        rel2="${rel_conf}/${required}"
        found_required=0
        while IFS= read -r entry; do
            [[ -n "$entry" ]] || continue
            case "$entry" in
                "$rel1"|./"$rel1"|"$rel2"|./"$rel2")
                    found_required=1
                    break
                    ;;
            esac
        done <<< "$list_out"
        (( found_required == 1 )) || return 1
    done < <(restore_required_files)

    return 0
}

purge_runtime_state_backups() {
    [[ -e "$RUNTIME_DIR" ]] || return 0
    rm -rf "$RUNTIME_DIR"
}

atomic_install_file() {
    local src="$1" dst="$2" mode="$3"
    local dst_dir tmp_dst

    [[ -f "$src" ]] || return 1
    dst_dir="$(dirname "$dst")"
    mkdir -p "$dst_dir" || return 1

    tmp_dst="$(mktemp "$dst_dir/.tmp.$(basename "$dst").XXXXXX")" || return 1

    if command -v install >/dev/null 2>&1; then
        if ! install -m "$mode" "$src" "$tmp_dst"; then
            rm -f "$tmp_dst"
            return 1
        fi
    else
        if ! cp -f "$src" "$tmp_dst"; then
            rm -f "$tmp_dst"
            return 1
        fi
        if ! chmod "$mode" "$tmp_dst" 2>/dev/null; then
            rm -f "$tmp_dst"
            return 1
        fi
    fi

    if ! mv -f "$tmp_dst" "$dst"; then
        rm -f "$tmp_dst"
        return 1
    fi
    return 0
}

make_file_snapshot() {
    local file="$1" snap
    validate_runtime_managed_paths_safe || return 1
    snap="$(safe_mktemp_file nft-manager-file.XXXXXX)" || return 1
    if [[ -f "$file" ]]; then
        cp -a "$file" "$snap" || { rm -f "$snap"; return 1; }
    else
        : > "$snap" || { rm -f "$snap"; return 1; }
    fi
    printf '%s' "$snap"
}

revert_file_from_snapshot() {
    local file="$1" snap="$2"
    atomic_install_file "$snap" "$file" 600
}

dir_path_has_symlink_component() {
    local path="$1" logical physical
    [[ -n "$path" ]] || return 0
    [[ -d "$path" ]] || return 0
    logical="$(cd -- "$path" 2>/dev/null && pwd -L)" || return 0
    physical="$(cd -P -- "$path" 2>/dev/null && pwd -P)" || return 0
    [[ "$logical" != "$physical" ]]
}

tmp_parent_dir() {
    local candidate
    for candidate in "${TMPDIR:-}" /tmp /var/tmp "$CONF_DIR" .; do
        [[ -n "$candidate" ]] || continue
        [[ -L "$candidate" ]] && continue
        [[ -d "$candidate" && -w "$candidate" && -x "$candidate" ]] || continue
        dir_path_has_symlink_component "$candidate" && continue
        printf '%s' "$candidate"
        return 0
    done
    return 1
}

safe_mktemp_file() {
    local template="$1"
    local parent
    parent="$(tmp_parent_dir)" || return 1
    mktemp "$parent/$template"
}

safe_mktemp_dir() {
    local template="$1"
    local parent
    parent="$(tmp_parent_dir)" || return 1
    mktemp -d "$parent/$template"
}

atomic_rewrite_file_from_stdin() {
    local file="$1" mode="$2" tmp
    tmp="$(mktemp "$(dirname "$file")/.tmp.$(basename "$file").XXXXXX")" || return 1
    if ! cat > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    if ! atomic_install_file "$tmp" "$file" "$mode"; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
    return 0
}

append_line_atomic() {
    local file="$1" line="$2" tmp last_char
    validate_runtime_managed_paths_safe || return 1
    tmp="$(mktemp "$(dirname "$file")/.tmp.$(basename "$file").XXXXXX")" || return 1

    if [[ -f "$file" ]]; then
        if ! cat -- "$file" > "$tmp"; then
            rm -f "$tmp"
            return 1
        fi
        if [[ -s "$file" ]]; then
            last_char="$(tail -c 1 -- "$file" 2>/dev/null || true)"
            if [[ -n "$last_char" ]]; then
                printf '\n' >> "$tmp" || { rm -f "$tmp"; return 1; }
            fi
        fi
    elif [[ -e "$file" ]]; then
        rm -f "$tmp"
        return 1
    fi

    if ! printf '%s\n' "$line" >> "$tmp"; then
        rm -f "$tmp"
        return 1
    fi

    if ! atomic_install_file "$tmp" "$file" 600; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
    return 0
}

delete_physical_line_atomic() {
    local file="$1" line_no="$2" tmp
    [[ "$line_no" =~ ^[0-9]+$ ]] || return 1
    validate_runtime_managed_paths_safe || return 1
    [[ -f "$file" ]] || return 1

    tmp="$(mktemp "$(dirname "$file")/.tmp.$(basename "$file").XXXXXX")" || return 1
    if ! awk -v target="$line_no" 'NR != target { print }' "$file" > "$tmp"; then
        rm -f "$tmp"
        return 1
    fi
    if ! atomic_install_file "$tmp" "$file" 600; then
        rm -f "$tmp"
        return 1
    fi
    rm -f "$tmp"
    return 0
}

apply_with_file_rollback() {
    local file="$1" snap="$2" fail_msg="$3" success_msg="${4:-}"
    if apply_rules; then
        rm -f "$snap"
        [[ -n "$success_msg" ]] && log_ok "$success_msg"
        return 0
    fi

    if revert_file_from_snapshot "$file" "$snap"; then
        log_warn "$fail_msg 已撤销本次文件修改。"
    else
        log_error "$fail_msg 且文件回滚失败，请手动检查：$file"
    fi
    rm -f "$snap"
    return 1
}

make_dir_snapshot() {
    local dir="$1" snap
    validate_runtime_managed_paths_safe || return 1
    snap="$(safe_mktemp_dir nft-manager-dir.XXXXXX)" || return 1
    if [[ -d "$dir" ]]; then
        cp -a "$dir"/. "$snap"/ || { rm -rf "$snap"; return 1; }
    fi
    printf '%s' "$snap"
}

restore_dir_from_snapshot() {
    local dir="$1" snap="$2"
    rm -rf "$dir" || return 1
    mkdir -p "$dir" || return 1
    cp -a "$snap"/. "$dir"/ || return 1
}

reset_settings_defaults() {
    INPUT_POLICY="drop"
    FORWARD_POLICY="drop"
    OUTPUT_POLICY="accept"
    ENABLE_DROP_LOG="no"
    DROP_LOG_RATE="10/second"
    WAN_IFACE=""
    AUTO_OPEN_SSH_PORT="yes"
    ALLOW_PING_V4="yes"
    PING_V4_RATE="5/second"
    ALLOW_PING_V6="yes"
    ALLOW_IPV6_ND="yes"
    ENABLE_IPV6_FORWARD="no"
    WARN_IPTABLES_NAT_CONFLICT="yes"
    ENABLE_COUNTERS="yes"
}

counter_stmt() {
    [[ "$ENABLE_COUNTERS" == "yes" ]] && printf 'counter '
}

trim() {
    local s="$1"
    s="${s#${s%%[![:space:]]*}}"
    s="${s%${s##*[![:space:]]}}"
    printf '%s' "$s"
}

strip_inline_comment() {
    printf '%s' "${1%%#*}"
}

normalize_line() {
    trim "$(strip_inline_comment "$1")"
}

normalize_rate_value() {
    printf '%s' "$1" | tr -d '[:space:]'
}

normalize_burst_value() {
    printf '%s' "$1" | tr -d '[:space:]'
}

normalize_iface_name() {
    local iface
    iface="$(trim "$1")"
    iface="${iface%%@*}"
    printf '%s' "$iface"
}

strip_wrapping_quotes() {
    local v="$1"
    if [[ "$v" =~ ^\".*\"$ ]]; then
        v="${v:1:${#v}-2}"
    elif [[ "$v" =~ ^\'.*\'$ ]]; then
        v="${v:1:${#v}-2}"
    fi
    printf '%s' "$v"
}

to_dec() {
    [[ "$1" =~ ^[0-9]+$ ]] || return 1
    printf '%u' "$((10#$1))"
}

normalize_port_value() {
    local n
    n="$(to_dec "$1")" || return 1
    printf '%s' "$n"
}

normalize_range_value() {
    local start end
    [[ "$1" =~ ^([0-9]+)-([0-9]+)$ ]] || return 1
    start="$(to_dec "${BASH_REMATCH[1]}")" || return 1
    end="$(to_dec "${BASH_REMATCH[2]}")" || return 1
    (( start <= end )) || return 1
    printf '%s-%s' "$start" "$end"
}

ipv4_canonical() {
    local ip="$1"
    local IFS='.'
    local -a octets=()
    local a b c d

    read -r -a octets <<< "$ip"
    [[ ${#octets[@]} -eq 4 ]] || return 1

    a="$(to_dec "${octets[0]}")" || return 1
    b="$(to_dec "${octets[1]}")" || return 1
    c="$(to_dec "${octets[2]}")" || return 1
    d="$(to_dec "${octets[3]}")" || return 1

    (( a >= 0 && a <= 255 )) || return 1
    (( b >= 0 && b <= 255 )) || return 1
    (( c >= 0 && c <= 255 )) || return 1
    (( d >= 0 && d <= 255 )) || return 1

    printf '%s.%s.%s.%s' "$a" "$b" "$c" "$d"
}

ipv4_cidr_canonical() {
    local input="$1" ip prefix start size mask network_ip
    if [[ "$input" == */* ]]; then
        ip="${input%/*}"
        prefix="${input#*/}"
        ip="$(ipv4_canonical "$ip")" || return 1
        prefix="$(to_dec "$prefix")" || return 1
        (( prefix >= 0 && prefix <= 32 )) || return 1
        start="$(ipv4_to_int "$ip")" || return 1
        if (( prefix == 0 )); then
            network_ip='0.0.0.0'
        elif (( prefix == 32 )); then
            network_ip="$ip"
        else
            size=$(( 1 << (32 - prefix) ))
            mask=$(( 0xFFFFFFFF ^ (size - 1) ))
            network_ip="$(int_to_ipv4 $(( start & mask )))" || return 1
        fi
        printf '%s/%s' "$network_ip" "$prefix"
    else
        ipv4_canonical "$input"
    fi
}

apply_setting_kv() {
    local key="$1" value="$2"
    case "$key" in
        INPUT_POLICY|FORWARD_POLICY|OUTPUT_POLICY|ENABLE_DROP_LOG|DROP_LOG_RATE|WAN_IFACE|AUTO_OPEN_SSH_PORT|ALLOW_PING_V4|PING_V4_RATE|ALLOW_PING_V6|ALLOW_IPV6_ND|ENABLE_IPV6_FORWARD|WARN_IPTABLES_NAT_CONFLICT|ENABLE_COUNTERS)
            printf -v "$key" '%s' "$value"
            ;;
    esac
}

ipv6_canonical() {
    command -v python3 >/dev/null 2>&1 || return 1
    python3 - "$1" <<'PY'
import ipaddress, sys
s = sys.argv[1]
try:
    if '/' in s:
        print(ipaddress.IPv6Network(s, strict=False).compressed)
    else:
        print(ipaddress.IPv6Address(s).compressed)
except Exception:
    sys.exit(1)
PY
}

validate_proto_menu() {
    [[ "$1" =~ ^(tcp|udp|both)$ ]]
}

validate_proto_rule() {
    [[ "$1" =~ ^(tcp|udp)$ ]]
}

validate_yesno() {
    [[ "$1" =~ ^(yes|no)$ ]]
}

validate_policy() {
    [[ "$1" =~ ^(accept|drop)$ ]]
}

validate_iface_name_syntax() {
    local iface
    iface="$(normalize_iface_name "$1")"
    [[ -z "$iface" ]] && return 0
    [[ "$iface" =~ ^[A-Za-z0-9_.:-]+$ ]]
}

iface_exists() {
    local iface
    iface="$(normalize_iface_name "$1")"
    [[ -z "$iface" ]] && return 1
    ip link show dev "$iface" >/dev/null 2>&1
}

validate_port() {
    local n
    n="$(normalize_port_value "$1")" || return 1
    (( n >= 1 && n <= 65535 ))
}

validate_range() {
    local normalized start end
    normalized="$(normalize_range_value "$1")" || return 1
    start="${normalized%-*}"
    end="${normalized#*-}"
    (( start >= 1 && end <= 65535 && start <= end ))
}

port_in_range_expr() {
    local port="$1" range="$2"
    local normalized start end port_num
    normalized="$(normalize_range_value "$range")" || return 1
    port_num="$(normalize_port_value "$port")" || return 1
    start="${normalized%-*}"
    end="${normalized#*-}"
    (( port_num >= start && port_num <= end ))
}

validate_rate() {
    [[ "$1" =~ ^[0-9]+(bytes|kbytes|mbytes|gbytes|packets)?/(second|minute|hour|day)$ ]] || \
    [[ "$1" =~ ^[0-9]+/(second|minute|hour|day)$ ]]
}

rate_is_byte_based() {
    [[ "$1" =~ (bytes|kbytes|mbytes|gbytes)/ ]]
}

validate_burst_token() {
    [[ "$1" =~ ^[0-9]+(packets|bytes|kbytes|mbytes|gbytes)?$ ]]
}

validate_connlimit() {
    local n
    n="$(to_dec "$1")" || return 1
    (( n >= 1 ))
}

validate_ipv4() {
    ipv4_canonical "$1" >/dev/null
}

validate_ipv4_cidr() {
    ipv4_cidr_canonical "$1" >/dev/null
}

validate_ipv6_basic() {
    local input="$1" addr prefix part left right left_count=0 right_count=0 total_count=0
    local -a groups=()
    if command -v python3 >/dev/null 2>&1; then
        python3 - "$input" <<'PY'
import ipaddress, sys
s = sys.argv[1]
try:
    if '/' in s:
        ipaddress.IPv6Network(s, strict=False)
    else:
        ipaddress.IPv6Address(s)
    sys.exit(0)
except Exception:
    sys.exit(1)
PY
    else
        addr="$input"
        prefix=""
        if [[ "$input" == */* ]]; then
            addr="${input%/*}"
            prefix="${input#*/}"
            prefix="$(to_dec "$prefix")" || return 1
            (( prefix >= 0 && prefix <= 128 )) || return 1
        fi
        [[ "$addr" =~ ^[0-9A-Fa-f:]+$ ]] || return 1
        [[ "$addr" == *:* ]] || return 1
        [[ "$addr" != *:::* ]] || return 1
        [[ "$addr" != *::*::* ]] || return 1

        if [[ "$addr" == *::* ]]; then
            left="${addr%%::*}"
            right="${addr##*::}"

            if [[ -n "$left" ]]; then
                IFS=':' read -r -a groups <<< "$left"
                left_count=${#groups[@]}
                for part in "${groups[@]}"; do
                    [[ -n "$part" && "$part" =~ ^[0-9A-Fa-f]{1,4}$ ]] || return 1
                done
            fi

            if [[ -n "$right" ]]; then
                IFS=':' read -r -a groups <<< "$right"
                right_count=${#groups[@]}
                for part in "${groups[@]}"; do
                    [[ -n "$part" && "$part" =~ ^[0-9A-Fa-f]{1,4}$ ]] || return 1
                done
            fi

            total_count=$(( left_count + right_count ))
            (( total_count < 8 )) || return 1
        else
            IFS=':' read -r -a groups <<< "$addr"
            total_count=${#groups[@]}
            (( total_count == 8 )) || return 1
            for part in "${groups[@]}"; do
                [[ -n "$part" && "$part" =~ ^[0-9A-Fa-f]{1,4}$ ]] || return 1
            done
        fi
    fi
}

validate_ip_or_cidr() {
    local input="$1"
    if [[ "$input" == *:* ]]; then
        validate_ipv6_basic "$input"
    else
        validate_ipv4_cidr "$input"
    fi
}

is_ipv6_value() {
    [[ "$1" == *:* ]]
}

ensure_nft_installed() {
    if command -v nft >/dev/null 2>&1; then
        NFT_BIN="$(command -v nft)"
        return 0
    fi

    log_warn "正在安装 nftables..."
    if command -v apt-get >/dev/null 2>&1; then
        apt-get update -y && apt-get install -y nftables
    elif command -v dnf >/dev/null 2>&1; then
        dnf install -y nftables
    elif command -v yum >/dev/null 2>&1; then
        yum install -y nftables
    else
        log_error "未找到支持的包管理器，无法自动安装 nftables。"
        exit 1
    fi

    NFT_BIN="$(command -v nft 2>/dev/null || true)"
    [[ -z "$NFT_BIN" ]] && log_error "安装后仍未找到 nft 命令。" && exit 1
}

detect_wan_iface() {
    local iface=""

    iface="$(ip -4 route show default 2>/dev/null | awk '
        /default/ {
            for (i = 1; i <= NF; i++) {
                if ($i == "dev" && (i + 1) <= NF) {
                    print $(i + 1)
                    exit
                }
            }
        }
    ')"
    iface="$(normalize_iface_name "$iface")"

    if [[ -z "$iface" ]]; then
        iface="$(ip -4 route get 1.1.1.1 2>/dev/null | awk '
            {
                for (i = 1; i <= NF; i++) {
                    if ($i == "dev" && (i + 1) <= NF) {
                        print $(i + 1)
                        exit
                    }
                }
            }
        ')"
        iface="$(normalize_iface_name "$iface")"
    fi

    if [[ -z "$iface" ]]; then
        iface="$(ip -6 route show default 2>/dev/null | awk '
            /default/ {
                for (i = 1; i <= NF; i++) {
                    if ($i == "dev" && (i + 1) <= NF) {
                        print $(i + 1)
                        exit
                    }
                }
            }
        ')"
        iface="$(normalize_iface_name "$iface")"
    fi

    printf '%s' "$iface"
}

detect_ssh_ports() {
    local ports=""

    if command -v sshd >/dev/null 2>&1; then
        ports="$(sshd -T 2>/dev/null | awk '/^port / {print $2}' | sort -un | xargs echo 2>/dev/null || true)"
    fi

    if [[ -z "$ports" && -f /etc/ssh/sshd_config ]]; then
        ports="$(awk 'BEGIN{IGNORECASE=1} $1=="Port" && $2 ~ /^[0-9]+$/ {print $2}' /etc/ssh/sshd_config | sort -un | xargs echo 2>/dev/null || true)"
    fi

    [[ -z "$ports" ]] && ports="22"
    printf '%s' "$ports"
}

version_ge() {
    local current="$1" required="$2"
    [[ "$(printf '%s\n%s\n' "$required" "$current" | sort -V | tail -n1)" == "$current" ]]
}

get_nft_version() {
    "$NFT_BIN" --version 2>/dev/null | sed -n 's/^nftables v\([0-9][0-9.]*\).*/\1/p' | head -n1
}

get_kernel_version() {
    uname -r | cut -d- -f1
}

check_connlimit_support() {
    local nft_ver kernel_ver
    nft_ver="$(get_nft_version)"
    kernel_ver="$(get_kernel_version)"

    [[ -n "$nft_ver" ]] || { log_error "无法识别 nftables 版本，无法安全启用 connlimit。"; return 1; }
    [[ -n "$kernel_ver" ]] || { log_error "无法识别内核版本，无法安全启用 connlimit。"; return 1; }

    version_ge "$nft_ver" "0.9.0" || {
        log_error "当前 nftables 版本为 $nft_ver，connlimit 需要至少 0.9.0。"
        return 1
    }
    version_ge "$kernel_ver" "4.19.10" || {
        log_error "当前内核版本为 $kernel_ver，connlimit 需要至少 4.19.10。"
        return 1
    }

    return 0
}

parse_ratelimit_line() {
    local line="$1"
    local -a parts=()
    local rest maybe_rate maybe_burst compact_rate compact_burst

    read -r -a parts <<< "$line"
    (( ${#parts[@]} >= 3 )) || return 1

    PARSED_RATE_PROTO="${parts[0]}"
    PARSED_RATE_PORT="${parts[1]}"
    rest="${line#${parts[0]} }"
    rest="${rest#${parts[1]} }"

    maybe_burst=""
    maybe_rate="$rest"
    if [[ "$rest" =~ ^(.+)[[:space:]]+([^[:space:]]+)$ ]]; then
        compact_rate="$(normalize_rate_value "${BASH_REMATCH[1]}")"
        compact_burst="$(normalize_burst_value "${BASH_REMATCH[2]}")"
        if validate_rate "$compact_rate" && validate_burst_token "$compact_burst"; then
            maybe_rate="${BASH_REMATCH[1]}"
            maybe_burst="${BASH_REMATCH[2]}"
        fi
    fi

    compact_rate="$(normalize_rate_value "$maybe_rate")"
    validate_rate "$compact_rate" || return 1

    PARSED_RATE_VALUE="$compact_rate"
    PARSED_RATE_BURST=""
    PARSED_RATE_BURST_EMIT=""

    if [[ -n "$maybe_burst" ]]; then
        compact_burst="$(normalize_burst_value "$maybe_burst")"
        validate_burst_token "$compact_burst" || return 1
        if rate_is_byte_based "$compact_rate"; then
            [[ "$compact_burst" =~ ^[0-9]+(bytes|kbytes|mbytes|gbytes)$ ]] || return 1
            PARSED_RATE_BURST="$compact_burst"
            PARSED_RATE_BURST_EMIT="$compact_burst"
        else
            [[ "$compact_burst" =~ ^[0-9]+(packets)?$ ]] || return 1
            PARSED_RATE_BURST="$compact_burst"
            if [[ "$compact_burst" =~ packets$ ]]; then
                PARSED_RATE_BURST_EMIT="$compact_burst"
            else
                PARSED_RATE_BURST_EMIT="$compact_burst packets"
            fi
        fi
    fi

    return 0
}

canonicalize_entry() {
    local file="$1" raw="$2"
    local line proto port range src lport rip rport maxc first canon6 canon4
    local -a fields=()

    line="$(normalize_line "$raw")"
    [[ -n "$line" ]] || return 1
    read -r -a fields <<< "$line"
    (( ${#fields[@]} > 0 )) || return 1

    case "$file" in
        "$ALLOW_FILE"|"$BLOCK_PORT_FILE")
            (( ${#fields[@]} == 2 )) || return 1
            proto="${fields[0]}"
            port="${fields[1]}"
            validate_proto_rule "$proto" || return 1
            port="$(normalize_port_value "$port")" || return 1
            validate_port "$port" || return 1
            printf '%s %s' "$proto" "$port"
            ;;
        "$ALLOW_RANGE_FILE")
            (( ${#fields[@]} == 2 )) || return 1
            proto="${fields[0]}"
            range="${fields[1]}"
            validate_proto_rule "$proto" || return 1
            range="$(normalize_range_value "$range")" || return 1
            validate_range "$range" || return 1
            printf '%s %s' "$proto" "$range"
            ;;
        "$ALLOW_ACL_FILE")
            (( ${#fields[@]} == 3 )) || return 1
            proto="${fields[0]}"
            port="${fields[1]}"
            src="${fields[2]}"
            validate_proto_rule "$proto" || return 1
            port="$(normalize_port_value "$port")" || return 1
            validate_port "$port" || return 1
            validate_ip_or_cidr "$src" || return 1
            if is_ipv6_value "$src"; then
                canon6="$(ipv6_canonical "$src" 2>/dev/null || true)"
                [[ -n "$canon6" ]] && src="$canon6"
            else
                canon4="$(ipv4_cidr_canonical "$src" 2>/dev/null || true)"
                [[ -n "$canon4" ]] && src="$canon4"
            fi
            printf '%s %s %s' "$proto" "$port" "$src"
            ;;
        "$FORWARD_FILE")
            (( ${#fields[@]} == 4 || ${#fields[@]} == 5 )) || return 1
            proto="${fields[0]}"
            lport="${fields[1]}"
            rip="${fields[2]}"
            rport="${fields[3]}"
            src="${fields[4]:-}"
            validate_proto_rule "$proto" || return 1
            lport="$(normalize_port_value "$lport")" || return 1
            rport="$(normalize_port_value "$rport")" || return 1
            rip="$(ipv4_canonical "$rip" 2>/dev/null || true)"
            [[ -n "$rip" ]] || return 1
            validate_port "$lport" || return 1
            validate_port "$rport" || return 1
            if [[ -n "$src" ]]; then
                src="$(ipv4_cidr_canonical "$src" 2>/dev/null || true)"
                [[ -n "$src" ]] || return 1
                printf '%s %s %s %s %s' "$proto" "$lport" "$rip" "$rport" "$src"
            else
                printf '%s %s %s %s' "$proto" "$lport" "$rip" "$rport"
            fi
            ;;
        "$BLOCK_IP_FILE")
            (( ${#fields[@]} == 1 )) || return 1
            line="${fields[0]}"
            validate_ip_or_cidr "$line" || return 1
            if is_ipv6_value "$line"; then
                canon6="$(ipv6_canonical "$line" 2>/dev/null || true)"
                [[ -n "$canon6" ]] && line="$canon6"
            else
                canon4="$(ipv4_cidr_canonical "$line" 2>/dev/null || true)"
                [[ -n "$canon4" ]] && line="$canon4"
            fi
            printf '%s' "$line"
            ;;
        "$RATELIMIT_FILE")
            parse_ratelimit_line "$line" || return 1
            validate_proto_rule "$PARSED_RATE_PROTO" || return 1
            PARSED_RATE_PORT="$(normalize_port_value "$PARSED_RATE_PORT")" || return 1
            validate_port "$PARSED_RATE_PORT" || return 1
            if [[ -n "$PARSED_RATE_BURST" ]]; then
                printf '%s %s %s %s' "$PARSED_RATE_PROTO" "$PARSED_RATE_PORT" "$PARSED_RATE_VALUE" "$PARSED_RATE_BURST"
            else
                printf '%s %s %s' "$PARSED_RATE_PROTO" "$PARSED_RATE_PORT" "$PARSED_RATE_VALUE"
            fi
            ;;
        "$CONNLIMIT_FILE")
            (( ${#fields[@]} == 3 )) || return 1
            proto="${fields[0]}"
            port="${fields[1]}"
            maxc="${fields[2]}"
            validate_proto_rule "$proto" || return 1
            port="$(normalize_port_value "$port")" || return 1
            maxc="$(to_dec "$maxc")" || return 1
            validate_port "$port" || return 1
            validate_connlimit "$maxc" || return 1
            printf '%s %s %s' "$proto" "$port" "$maxc"
            ;;
        "$TRACE_FILE")
            if [[ "${fields[0]}" == "prerouting" ]]; then
                (( ${#fields[@]} == 3 || ${#fields[@]} == 4 )) || return 1
                proto="${fields[1]}"
                port="${fields[2]}"
                src="${fields[3]:-}"
            elif [[ "${fields[0]}" =~ ^(input|forward)$ ]]; then
                return 1
            else
                (( ${#fields[@]} == 2 || ${#fields[@]} == 3 )) || return 1
                proto="${fields[0]}"
                port="${fields[1]}"
                src="${fields[2]:-}"
            fi
            validate_proto_rule "$proto" || return 1
            port="$(normalize_port_value "$port")" || return 1
            validate_port "$port" || return 1
            if [[ -n "$src" ]]; then
                validate_ip_or_cidr "$src" || return 1
                if is_ipv6_value "$src"; then
                    canon6="$(ipv6_canonical "$src" 2>/dev/null || true)"
                    [[ -n "$canon6" ]] && src="$canon6"
                else
                    canon4="$(ipv4_cidr_canonical "$src" 2>/dev/null || true)"
                    [[ -n "$canon4" ]] && src="$canon4"
                fi
                printf '%s %s %s' "$proto" "$port" "$src"
            else
                printf '%s %s' "$proto" "$port"
            fi
            ;;
        *)
            printf '%s' "$line"
            ;;
    esac
}

line_exists() {
    local wanted file raw current
    wanted="$1"
    file="$2"

    wanted="$(canonicalize_entry "$file" "$wanted" 2>/dev/null || true)"
    [[ -n "$wanted" ]] || return 1

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        current="$(canonicalize_entry "$file" "$raw" 2>/dev/null || true)"
        [[ -z "$current" ]] && continue
        [[ "$current" == "$wanted" ]] && return 0
    done < "$file"

    return 1
}

append_unique_line() {
    local line file normalized
    line="$1"
    file="$2"
    normalized="$(canonicalize_entry "$file" "$line" 2>/dev/null || true)"
    [[ -n "$normalized" ]] || { log_error "规则格式无效，无法写入：$(normalize_line "$line")"; return 1; }

    if line_exists "$normalized" "$file"; then
        log_warn "规则已存在，已跳过：$normalized"
        return 2
    fi

    if ! append_line_atomic "$file" "$normalized"; then
        log_error "规则写入失败：$file"
        return 1
    fi

    return 0
}

append_unique_array_item() {
    local value="$1"
    shift
    local current
    for current in "$@"; do
        [[ "$current" == "$value" ]] && return 1
    done
    return 0
}

dedupe_scalar_array() {
    local item
    local -a out=()
    for item in "$@"; do
        [[ -z "$item" ]] && continue
        if append_unique_array_item "$item" "${out[@]}"; then
            out+=("$item")
        fi
    done
    printf '%s\n' "${out[@]}"
}

ipv4_to_int() {
    local canon="$1" a b c d
    canon="$(ipv4_canonical "$canon")" || return 1
    IFS='.' read -r a b c d <<< "$canon" || return 1
    printf '%u' "$(( (a << 24) | (b << 16) | (c << 8) | d ))"
}

int_to_ipv4() {
    local value="$1"
    printf '%d.%d.%d.%d' \
        "$(( (value >> 24) & 255 ))" \
        "$(( (value >> 16) & 255 ))" \
        "$(( (value >> 8) & 255 ))" \
        "$(( value & 255 ))"
}

ipv4_value_to_range() {
    local input="$1" ip prefix start size end mask

    if [[ "$input" == */* ]]; then
        ip="${input%/*}"
        prefix="${input#*/}"
        ip="$(ipv4_canonical "$ip")" || return 1
        prefix="$(to_dec "$prefix")" || return 1
        (( prefix >= 0 && prefix <= 32 )) || return 1
        start="$(ipv4_to_int "$ip")" || return 1
        if (( prefix == 0 )); then
            start=0
            end=4294967295
        else
            size=$(( 1 << (32 - prefix) ))
            mask=$(( 0xFFFFFFFF ^ (size - 1) ))
            start=$(( start & mask ))
            end=$(( start + size - 1 ))
        fi
    else
        ip="$(ipv4_canonical "$input")" || return 1
        start="$(ipv4_to_int "$ip")" || return 1
        end="$start"
    fi

    printf '%s %s' "$start" "$end"
}

collapse_ip_elements() {
    local family="$1"
    shift || true
    (( $# > 0 )) || return 0

    if command -v python3 >/dev/null 2>&1; then
        FAMILY="$family" python3 - "$@" <<'PY'
import ipaddress, os, sys
family = os.environ.get('FAMILY', 'ipv4')
items = []
for raw in sys.argv[1:]:
    s = raw.strip()
    if not s:
        continue
    try:
        if '/' in s:
            net = ipaddress.ip_network(s, strict=False)
        else:
            if family == 'ipv6':
                net = ipaddress.ip_network(f"{ipaddress.IPv6Address(s)}/128", strict=False)
            else:
                net = ipaddress.ip_network(f"{ipaddress.IPv4Address(s)}/32", strict=False)
        items.append(net)
    except Exception:
        pass
for net in ipaddress.collapse_addresses(items):
    print(net.compressed)
PY
        return 0
    fi

    if [[ "$family" != "ipv4" ]]; then
        dedupe_scalar_array "$@"
        return 0
    fi

    local item start end line cur_start cur_end out_start out_end
    local -a ranges=() merged=()

    for item in "$@"; do
        [[ -z "$item" ]] && continue
        read -r start end <<< "$(ipv4_value_to_range "$item" 2>/dev/null || true)"
        [[ -n "$start" && -n "$end" ]] || continue
        ranges+=("$start $end")
    done

    (( ${#ranges[@]} > 0 )) || return 0

    mapfile -t ranges < <(printf '%s
' "${ranges[@]}" | sort -n -k1,1 -k2,2)

    for line in "${ranges[@]}"; do
        read -r cur_start cur_end <<< "$line"
        if (( ${#merged[@]} == 0 )); then
            merged+=("$cur_start $cur_end")
            continue
        fi
        read -r out_start out_end <<< "${merged[-1]}"
        if (( cur_start <= out_end + 1 )); then
            (( cur_end > out_end )) && merged[-1]="$out_start $cur_end"
        else
            merged+=("$cur_start $cur_end")
        fi
    done

    for line in "${merged[@]}"; do
        read -r start end <<< "$line"
        if (( start == end )); then
            int_to_ipv4 "$start"
        else
            printf '%s-%s
' "$(int_to_ipv4 "$start")" "$(int_to_ipv4 "$end")"
        fi
    done
}

merge_port_ranges() {
    (( $# > 0 )) || return 0

    if command -v python3 >/dev/null 2>&1; then
        python3 - "$@" <<'PY'
import sys
ranges = []
for raw in sys.argv[1:]:
    s = raw.strip()
    if not s or '-' not in s:
        continue
    a, b = s.split('-', 1)
    try:
        start, end = int(a), int(b)
    except ValueError:
        continue
    if start > end:
        start, end = end, start
    ranges.append((start, end))
if not ranges:
    raise SystemExit(0)
ranges.sort()
merged = []
for start, end in ranges:
    if not merged or start > merged[-1][1] + 1:
        merged.append([start, end])
    else:
        merged[-1][1] = max(merged[-1][1], end)
for start, end in merged:
    print(f"{start}-{end}")
PY
        return 0
    fi

    local raw start end line cur_start cur_end out_start out_end
    local -a ranges=() merged=()

    for raw in "$@"; do
        [[ "$raw" =~ ^([0-9]+)-([0-9]+)$ ]] || continue
        start="${BASH_REMATCH[1]}"
        end="${BASH_REMATCH[2]}"
        (( start > end )) && { cur_start="$start"; start="$end"; end="$cur_start"; }
        ranges+=("$start $end")
    done

    (( ${#ranges[@]} > 0 )) || return 0

    mapfile -t ranges < <(printf '%s
' "${ranges[@]}" | sort -n -k1,1 -k2,2)

    for line in "${ranges[@]}"; do
        read -r cur_start cur_end <<< "$line"
        if (( ${#merged[@]} == 0 )); then
            merged+=("$cur_start $cur_end")
            continue
        fi
        read -r out_start out_end <<< "${merged[-1]}"
        if (( cur_start <= out_end + 1 )); then
            (( cur_end > out_end )) && merged[-1]="$out_start $cur_end"
        else
            merged+=("$cur_start $cur_end")
        fi
    done

    for line in "${merged[@]}"; do
        read -r start end <<< "$line"
        printf '%s-%s
' "$start" "$end"
    done
}
build_set_block() {
    local outfile="$1" set_name="$2" set_type="$3" set_flags="$4"
    shift 4
    local -a elements=("$@")

    {
        echo "    set $set_name {"
        echo "        type $set_type"
        [[ -n "$set_flags" ]] && echo "        flags $set_flags"
        if [[ ${#elements[@]} -gt 0 ]]; then
            echo -n "        elements = { "
            local first=1 el
            for el in "${elements[@]}"; do
                [[ -z "$el" ]] && continue
                [[ $first -eq 1 ]] || echo -n ", "
                echo -n "$el"
                first=0
            done
            echo " }"
        fi
        echo "    }"
    } >> "$outfile"
}

count_active_entries() {
    local file="$1" raw line count=0
    while IFS= read -r raw || [[ -n "$raw" ]]; do
        line="$(normalize_line "$raw")"
        [[ -z "$line" ]] && continue
        count=$((count + 1))
    done < "$file"
    printf '%s' "$count"
}

count_valid_entries() {
    local file="$1" raw line count=0
    while IFS= read -r raw || [[ -n "$raw" ]]; do
        line="$(canonicalize_entry "$file" "$raw" 2>/dev/null || true)"
        [[ -z "$line" ]] && continue
        count=$((count + 1))
    done < "$file"
    printf '%s' "$count"
}

has_active_entries() {
    [[ "$(count_active_entries "$1")" -gt 0 ]]
}

has_valid_entries() {
    [[ "$(count_valid_entries "$1")" -gt 0 ]]
}

count_cidr_entries() {
    local file="$1" raw canon count=0
    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$file" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        [[ "$canon" == */* ]] && count=$((count + 1))
    done < "$file"
    printf '%s' "$count"
}

count_forward_source_entries() {
    local raw line proto lport rip rport src count=0
    while IFS= read -r raw || [[ -n "$raw" ]]; do
        line="$(canonicalize_entry "$FORWARD_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$line" ]] && continue
        src=""
        read -r proto lport rip rport src <<< "$line"
        [[ -n "$src" ]] && count=$((count + 1))
    done < "$FORWARD_FILE"
    printf '%s' "$count"
}

count_invalid_entries() {
    local file="$1" raw normalized canon count=0
    while IFS= read -r raw || [[ -n "$raw" ]]; do
        normalized="$(normalize_line "$raw")"
        [[ -z "$normalized" ]] && continue
        canon="$(canonicalize_entry "$file" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && count=$((count + 1))
    done < "$file"
    printf '%s' "$count"
}

has_any_invalid_rule_entries() {
    local file
    for file in         "$ALLOW_FILE" "$ALLOW_RANGE_FILE" "$ALLOW_ACL_FILE" "$FORWARD_FILE"         "$BLOCK_IP_FILE" "$BLOCK_PORT_FILE" "$RATELIMIT_FILE" "$CONNLIMIT_FILE" "$TRACE_FILE"
