    if [[ ! -s "$LAST_ACTIVE_RULESET_FILE" ]]; then
        log_warn "没有可恢复的受管运行态快照。"
        return 1
    fi

    grep -Eq '^[[:space:]]*table[[:space:]]+' "$LAST_ACTIVE_RULESET_FILE" 2>/dev/null && snap_has_tables=1

    if restore_managed_snapshot "$LAST_ACTIVE_RULESET_FILE"; then
        if ! load_runtime_settings; then
            log_warn "受管配置文件或目录当前不安全；已跳过配置侧运行态重载，仅继续按快照同步 sysctl。"
        fi
        if ! sync_sysctl_from_snapshot "$LAST_ACTIVE_RULESET_FILE"; then
            sysctl_sync_ok=0
        fi
        mark_service_inactive_after_direct_runtime_restore
        if (( snap_has_tables == 1 )); then
            if (( sysctl_sync_ok == 1 )); then
                case "$SYSCTL_LAST_SYNC_MODE" in
                    full) log_ok "已恢复最近一次受管运行态快照。" ;;
                    runtime-fallback) log_warn "受管运行态快照已恢复，sysctl 当前运行态已同步，但 sysctl --system 失败并已回退到直接写入运行态。" ;;
                    runtime-only) log_warn "受管运行态快照已恢复，当前运行态已同步，但 sysctl 持久化文件未成功更新。" ;;
                    *) log_ok "已恢复最近一次受管运行态快照。" ;;
                esac
            else
                log_warn "受管运行态快照已恢复，但 sysctl 同步失败。"
            fi
        else
            if (( sysctl_sync_ok == 1 )); then
                case "$SYSCTL_LAST_SYNC_MODE" in
                    full) log_ok "已恢复最近一次受管运行态快照（空受管规则集）。" ;;
                    runtime-fallback) log_warn "空受管运行态快照已恢复，sysctl 当前运行态已同步，但 sysctl --system 失败并已回退到直接写入运行态。" ;;
                    runtime-only) log_warn "空受管运行态快照已恢复，当前运行态已同步，但 sysctl 持久化文件未成功更新。" ;;
                    *) log_ok "已恢复最近一次受管运行态快照（空受管规则集）。" ;;
                esac
            else
                log_warn "空受管运行态快照已恢复，但 sysctl 同步失败。"
            fi
        fi
        log_warn "注意：仅恢复了当前运行态的受管表，未同步 .list / settings.conf；重启后仍以 $NFT_RULE_FILE 为准。"
        return 0
    else
        log_error "恢复受管运行态快照失败。"
        return 1
    fi
}

