    active_state="$(systemctl is-active nft-manager.service 2>/dev/null || echo unknown)"
    if [[ "$active_state" =~ ^(active|activating|deactivating|failed)$ ]]; then
        systemctl stop nft-manager.service >/dev/null 2>&1 || true
    fi
    systemctl reset-failed nft-manager.service >/dev/null 2>&1 || true

    return "$rc"
}

