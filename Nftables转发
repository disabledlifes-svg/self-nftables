sysctl_key_exists() {
    local key="$1"
    local sysctl_path="/proc/sys/${key//./\/}"
    [[ -e "$sysctl_path" ]]
}

write_sysctl_values() {
    local v4="$1" v6="$2" tmp_sysctl persist_ok=0 runtime_v4_ok=0 runtime_v6_ok=0 runtime_overall_ok=0 include_ipv6=1

    SYSCTL_LAST_SYNC_MODE="failed"

    if ! sysctl_key_exists "net.ipv6.conf.all.forwarding"; then
        include_ipv6=0
    fi

    tmp_sysctl="$(safe_mktemp_file nft-manager-sysctl.XXXXXX.conf)" || {
        tmp_sysctl=""
        log_warn "无法创建临时 sysctl 文件；将跳过持久化写入并继续尝试仅同步当前运行态。"
    }

    if [[ -n "$tmp_sysctl" ]]; then
        {
            printf 'net.ipv4.ip_forward=%s
' "$v4"
            if (( include_ipv6 == 1 )); then
                printf 'net.ipv6.conf.all.forwarding=%s
' "$v6"
            fi
        } > "$tmp_sysctl" || {
            rm -f "$tmp_sysctl"
            tmp_sysctl=""
            log_warn "无法生成 sysctl 持久化配置内容；将继续尝试仅更新当前运行态。"
        }
    fi

    if [[ -n "$tmp_sysctl" && -f "$tmp_sysctl" ]]; then
        if atomic_install_file "$tmp_sysctl" "$SYSCTL_FILE" 644 2>/dev/null; then
            persist_ok=1
        else
            log_warn "无法原子写入 sysctl 持久化文件：$SYSCTL_FILE；将继续尝试仅更新当前运行态。"
        fi
    fi
    [[ -n "$tmp_sysctl" ]] && rm -f "$tmp_sysctl"

    if (( include_ipv6 == 0 )); then
        log_warn "当前环境不存在 IPv6 forwarding sysctl 键；持久化与运行态同步将仅处理 IPv4。"
    fi

    if (( persist_ok == 1 )); then
        if sysctl --system >/dev/null 2>&1; then
            SYSCTL_LAST_SYNC_MODE="full"
            return 0
        fi
        log_warn "sysctl --system 执行失败，尝试直接写入当前运行态参数。"
    fi

    if sysctl -w net.ipv4.ip_forward="$v4" >/dev/null 2>&1; then
        runtime_v4_ok=1
    fi

    if (( include_ipv6 == 1 )); then
        if sysctl -w net.ipv6.conf.all.forwarding="$v6" >/dev/null 2>&1; then
            runtime_v6_ok=1
        fi
    else
        runtime_v6_ok=1
    fi

    if (( runtime_v4_ok == 1 && runtime_v6_ok == 1 )); then
        runtime_overall_ok=1
    fi

    if (( runtime_overall_ok == 1 )); then
        if (( persist_ok == 1 )); then
            SYSCTL_LAST_SYNC_MODE="runtime-fallback"
        else
            SYSCTL_LAST_SYNC_MODE="runtime-only"
        fi
        return 0
    fi

    log_error "无法同步 sysctl 持久化文件与当前运行态，请手动检查：$SYSCTL_FILE"
    SYSCTL_LAST_SYNC_MODE="failed"
    return 1
}
read_runtime_sysctl_bool() {
    local key="$1" value=""
    value="$(sysctl -n "$key" 2>/dev/null || true)"
    [[ "$value" =~ ^[01]$ ]] || return 1
    printf '%s' "$value"
}

sync_sysctl_from_snapshot() {
    local snap="$1"
    local v4 v6 meta_rc

    snapshot_metadata_read_values "$snap"
    meta_rc=$?

    if (( meta_rc == 0 || meta_rc == 3 )); then
        v4="$SNAPSHOT_META_V4"
        v6="$SNAPSHOT_META_V6"
    elif (( meta_rc == 2 )); then
        if grep -q 'dnat to ' "$snap" 2>/dev/null; then
            v4=1
        else
            v4=0
        fi

        v6="$(read_runtime_sysctl_bool net.ipv6.conf.all.forwarding 2>/dev/null || true)"
        if [[ -z "$v6" ]]; then
            if [[ "$ENABLE_IPV6_FORWARD" == "yes" ]]; then
                v6=1
            else
                v6=0
            fi
        fi
    else
        return 1
    fi

    write_sysctl_values "$v4" "$v6"
}

write_sysctl() {
    local desired_v4 desired_v6

    if has_valid_entries "$FORWARD_FILE"; then
        desired_v4=1
    else
        desired_v4=0
    fi

    if [[ "$ENABLE_IPV6_FORWARD" == "yes" ]]; then
