    fi
    if ! validate_managed_source_files_safe; then
        return 1
    fi
    chmod 700 "$CONF_DIR" "$BACKUP_DIR" "$RUNTIME_DIR" 2>/dev/null || true
    old_umask="$(umask)"
    umask 077
