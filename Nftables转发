show_status() {
    local nft_ver kernel_ver forward_rules acl_cidr_count forward_source_count syntax_state wan_state managed_runtime_state auto_ssh_runtime_ports
    local ipv4_forward_state ipv6_forward_state
    local invalid_allow invalid_range invalid_acl invalid_forward invalid_block_ip invalid_block_port invalid_rate invalid_conn invalid_trace
    local service_enabled service_active service_active_display saved_rules_state

    if ! load_runtime_settings; then
        log_error "受管配置文件或目录不安全，无法展示状态页。"
        return 1
    fi
    nft_ver="$(get_nft_version)"
    kernel_ver="$(get_kernel_version)"
    forward_rules="$(count_effective_entries "$FORWARD_FILE")"
    acl_cidr_count="$(count_effective_acl_cidr_entries)"
    forward_source_count="$(count_effective_forward_source_entries)"
    ipv4_forward_state="$(sysctl -n net.ipv4.ip_forward 2>/dev/null || echo unknown)"
    ipv6_forward_state="$(sysctl -n net.ipv6.conf.all.forwarding 2>/dev/null || echo unknown)"
    managed_runtime_state="$(managed_tables_runtime_state)"
    auto_ssh_runtime_ports="$(format_auto_ssh_ports)"
    invalid_allow="$(count_invalid_entries "$ALLOW_FILE")"
    invalid_range="$(count_invalid_entries "$ALLOW_RANGE_FILE")"
    invalid_acl="$(count_invalid_entries "$ALLOW_ACL_FILE")"
    invalid_forward="$(count_invalid_entries "$FORWARD_FILE")"
    invalid_block_ip="$(count_invalid_entries "$BLOCK_IP_FILE")"
    invalid_block_port="$(count_invalid_entries "$BLOCK_PORT_FILE")"
    invalid_rate="$(count_invalid_entries "$RATELIMIT_FILE")"
    invalid_conn="$(count_invalid_entries "$CONNLIMIT_FILE")"
    invalid_trace="$(count_invalid_entries "$TRACE_FILE")"

    if [[ -n "$WAN_IFACE" ]] && iface_exists "$WAN_IFACE"; then
        wan_state="$WAN_IFACE"
    else
        wan_state="${WAN_IFACE:-<auto/unknown>}"
    fi

    if full_syntax_check_quiet; then
        syntax_state='OK'
    else
        syntax_state='FAILED'
    fi

    if [[ -s "$NFT_RULE_FILE" ]]; then
        saved_rules_state='present'
    else
        saved_rules_state='missing'
    fi

    if systemd_is_usable; then
        if systemctl is-enabled nft-manager.service >/dev/null 2>&1; then
            service_enabled='enabled'
        else
            service_enabled='disabled'
        fi
        service_active="$(systemctl is-active nft-manager.service 2>/dev/null || echo unknown)"
        service_active_display="$service_active"
        if [[ "$managed_runtime_state" == unknown* ]]; then
            service_active_display="$service_active (受管表状态查询失败: $managed_runtime_state)"
        elif [[ "$service_active" == 'active' && "$managed_runtime_state" == 'missing' ]]; then
            service_active_display='active (unit 保持激活，但当前受管表为空)'
        elif [[ "$service_active" == 'active' && "$managed_runtime_state" == partial* ]]; then
            service_active_display="active (unit 保持激活，但受管表仅部分存在: $managed_runtime_state)"
        elif [[ "$service_active" == 'inactive' && "$managed_runtime_state" != 'missing' ]]; then
            service_active_display='inactive (规则已直接加载到运行态，属正常现象)'
        elif [[ "$service_active" == 'inactive' && "$managed_runtime_state" == 'missing' && "$saved_rules_state" == 'present' ]]; then
            service_active_display='inactive (规则文件已保存，但当前未通过 systemd 加载到运行态)'
        elif [[ "$service_active" == 'failed' && "$managed_runtime_state" != 'missing' ]]; then
            service_active_display='failed (当前运行态仍存在受管表，但本轮不是由 systemd 直载)'
        elif [[ "$service_active" == 'failed' && "$managed_runtime_state" == 'missing' && "$saved_rules_state" == 'present' ]]; then
            service_active_display='failed (规则文件已保存，但当前未加载到运行态)'
        fi
    else
        service_enabled='no-systemd'
        service_active='no-systemd'
        service_active_display='no-systemd'
    fi

    echo -e "${CYAN}--- 运行状态总览 ---${PLAIN}"
    printf 'nftables 版本: %s\n' "${nft_ver:-unknown}"
    printf '内核版本: %s\n' "${kernel_ver:-unknown}"
    printf 'WAN_IFACE: %s\n' "$wan_state"
    printf 'SSH 自动放行: %s\n' "$AUTO_OPEN_SSH_PORT"
    printf 'SSH 运行时补放行端口: %s\n' "$auto_ssh_runtime_ports"
    printf 'IPv4 转发(sysctl): %s\n' "$ipv4_forward_state"
    printf 'IPv6 转发(sysctl): %s\n' "$ipv6_forward_state"
    printf 'systemd 开机启用: %s\n' "$service_enabled"
    printf 'systemd 当前状态: %s\n' "$service_active_display"
    printf '已保存规则文件: %s\n' "$saved_rules_state"
    printf '受管表运行态: %s\n' "$managed_runtime_state"
    printf 'DNAT 有效规则数: %s\n' "$forward_rules"
    printf 'ACL 含 CIDR 规则数: %s\n' "$acl_cidr_count"
    printf 'DNAT 含源限制规则数: %s\n' "$forward_source_count"
    printf '完整语法干跑: %s\n' "$syntax_state"
    printf '无效条目统计: allow=%s range=%s acl=%s forward=%s block_ip=%s block_port=%s ratelimit=%s connlimit=%s trace=%s\n' \
        "$invalid_allow" "$invalid_range" "$invalid_acl" "$invalid_forward" "$invalid_block_ip" "$invalid_block_port" "$invalid_rate" "$invalid_conn" "$invalid_trace"
    echo
}

