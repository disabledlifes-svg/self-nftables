port_is_effectively_allowed() {
    local proto="$1" port="$2"
    local raw canon p v src

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$ALLOW_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        read -r p v <<< "$canon"
        [[ "$p" == "$proto" && "$v" == "$port" ]] && return 0
    done < "$ALLOW_FILE"

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$ALLOW_RANGE_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        read -r p v <<< "$canon"
        if [[ "$p" == "$proto" ]] && port_in_range_expr "$port" "$v"; then
            return 0
        fi
    done < "$ALLOW_RANGE_FILE"

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$ALLOW_ACL_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        read -r p v src <<< "$canon"
        [[ "$p" == "$proto" && "$v" == "$port" ]] && return 0
    done < "$ALLOW_ACL_FILE"

    return 1
}

port_is_globally_allowed() {
    local proto="$1" port="$2"
    local raw canon p v

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$ALLOW_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        read -r p v <<< "$canon"
        [[ "$p" == "$proto" && "$v" == "$port" ]] && return 0
    done < "$ALLOW_FILE"

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$ALLOW_RANGE_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        read -r p v <<< "$canon"
        if [[ "$p" == "$proto" ]] && port_in_range_expr "$port" "$v"; then
            return 0
        fi
    done < "$ALLOW_RANGE_FILE"

    return 1
}

ssh_ports_already_allowed() {
    local ssh_port="$1"
    port_is_globally_allowed tcp "$ssh_port"
}

port_is_globally_blocked() {
    local proto="$1" port="$2"
    local raw canon p v

    while IFS= read -r raw || [[ -n "$raw" ]]; do
        canon="$(canonicalize_entry "$BLOCK_PORT_FILE" "$raw" 2>/dev/null || true)"
        [[ -z "$canon" ]] && continue
        read -r p v <<< "$canon"
        [[ "$p" == "$proto" && "$v" == "$port" ]] && return 0
    done < "$BLOCK_PORT_FILE"

    return 1
}

ssh_port_needs_runtime_rescue() {
    local ssh_port="$1"
    port_is_globally_blocked tcp "$ssh_port" && return 0
    port_is_globally_allowed tcp "$ssh_port" && return 1
    return 0
}

get_auto_ssh_rescue_ports() {
    [[ "$INPUT_POLICY" == "drop" ]] || return 0
    [[ "$AUTO_OPEN_SSH_PORT" == "yes" ]] || return 0

    local ssh_ports port
    local -a rescue_ports=()

    ssh_ports="$(detect_ssh_ports)"
    for port in $ssh_ports; do
        validate_port "$port" || continue
        if ssh_port_needs_runtime_rescue "$port"; then
            rescue_ports+=("$port")
        fi
    done

    (( ${#rescue_ports[@]} > 0 )) || return 0
    mapfile -t rescue_ports < <(dedupe_scalar_array "${rescue_ports[@]}")
    printf '%s
' "${rescue_ports[@]}"
}

warn_auto_ssh_runtime_allow() {
    local -a auto_ports=()
    mapfile -t auto_ports < <(get_auto_ssh_rescue_ports)
    (( ${#auto_ports[@]} > 0 )) || return 0
    log_warn "检测到 SSH 端口未被安全放行；本次仅在当前运行态自动补放行 tcp/$(printf '%s ' "${auto_ports[@]}" | sed 's/[[:space:]]*$//')，不会改写 allow.list，也不会写入持久化 rules.nft。"
}

format_auto_ssh_ports() {
    local -a auto_ports=()
    mapfile -t auto_ports < <(get_auto_ssh_rescue_ports)
    (( ${#auto_ports[@]} > 0 )) || { printf '%s' '-'; return 0; }
    printf 'tcp/%s' "${auto_ports[0]}"
    local i
    for (( i = 1; i < ${#auto_ports[@]}; i++ )); do
        printf ',tcp/%s' "${auto_ports[$i]}"
    done
}

