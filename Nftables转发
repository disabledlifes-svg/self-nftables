restore_managed_snapshot() {
    local snap="$1" snap_has_tables=0 current_snap="" current_has_tables=0
    [[ -f "$snap" && -s "$snap" ]] || return 1

    managed_nft_content_is_usable "$snap" no || return 1

    if grep -Eq '^[[:space:]]*table[[:space:]]+' "$snap" 2>/dev/null; then
        snap_has_tables=1
        "$NFT_BIN" -c -f "$snap" >/dev/null 2>&1 || return 1
    fi

    current_snap="$(safe_mktemp_file nft-manager-restore-current.XXXXXX.nft 2>/dev/null || true)"
    if [[ -n "$current_snap" ]]; then
        if capture_managed_snapshot_to_file "$current_snap"; then
            grep -Eq '^[[:space:]]*table[[:space:]]+' "$current_snap" 2>/dev/null && current_has_tables=1
        else
            rm -f "$current_snap"
            current_snap=""
        fi
    fi

    if ! drop_managed_tables_quiet; then
        rm -f "$current_snap"
        return 1
    fi

    if (( snap_has_tables == 0 )); then
        rm -f "$current_snap"
        return 0
    fi

    if "$NFT_BIN" -f "$snap"; then
        rm -f "$current_snap"
        return 0
    fi

    if [[ -n "$current_snap" ]]; then
        drop_managed_tables_quiet >/dev/null 2>&1 || true
        if (( current_has_tables == 1 )); then
            if "$NFT_BIN" -f "$current_snap" >/dev/null 2>&1; then
                log_warn "恢复受管运行态快照失败，已回滚到切换前的受管运行态。"
            else
                log_error "恢复受管运行态快照失败，且回滚到切换前受管运行态也失败了。"
            fi
        else
            log_warn "恢复受管运行态快照失败，已回滚到切换前的空受管运行态。"
        fi
        rm -f "$current_snap"
    else
        log_warn "恢复受管运行态快照失败，且未能捕获切换前受管运行态快照，无法自动回滚。"
